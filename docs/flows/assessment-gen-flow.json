{
  "version": "5.1",
  "data_api_version": "3.0",
  "routing_model": {
    "SPEC": [
      "SEEN_UNSEEN"
    ],
    "SEEN_UNSEEN": [
      "OBJ_SUBJ",
      "SUCCESS"
    ],
    "OBJ_SUBJ": [
      "PICK_TYPES"
    ],
    "PICK_TYPES": [
      "SET_COUNTS"
    ],
    "SET_COUNTS": [
      "SUCCESS"
    ]
  },
  "screens": [
    {
      "id": "SPEC",
      "title": "New assessment",
      "data": {
        "grade_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "1",
              "title": "Grade 1"
            },
            {
              "id": "2",
              "title": "Grade 2"
            },
            {
              "id": "3",
              "title": "Grade 3"
            },
            {
              "id": "4",
              "title": "Grade 4"
            },
            {
              "id": "5",
              "title": "Grade 5"
            }
          ]
        },
        "subject_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "Eng",
              "title": "English"
            },
            {
              "id": "Maths",
              "title": "Maths"
            },
            {
              "id": "Urdu",
              "title": "Urdu"
            },
            {
              "id": "Science",
              "title": "Science"
            },
            {
              "id": "Islamiat",
              "title": "Islamiat"
            },
            {
              "id": "SST",
              "title": "Social Studies"
            },
            {
              "id": "GenK",
              "title": "General Knowledge"
            }
          ]
        },
        "output_format_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "pdf",
              "title": "PDF",
              "description": "Print-ready. Best for printing straight to a class set."
            },
            {
              "id": "docx",
              "title": "Word",
              "description": "Editable. Tweak questions or scoring before printing."
            }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Assessment builder"
          },
          {
            "type": "TextSubheading",
            "text": "Pick what to test. We'll build the paper and send you a PDF."
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "generation_type",
                "label": "Type",
                "required": true,
                "data-source": [
                  {
                    "id": "exam",
                    "title": "Exam",
                    "description": "A full graded paper"
                  },
                  {
                    "id": "class_assessment",
                    "title": "Classroom practice",
                    "description": "Quick in-class practice"
                  }
                ]
              },
              {
                "type": "Dropdown",
                "name": "grade",
                "label": "Grade",
                "required": true,
                "data-source": "${data.grade_options}",
                "on-select-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "grade_changed",
                    "grade": "${form.grade}"
                  }
                }
              },
              {
                "type": "Dropdown",
                "name": "subject",
                "label": "Subject",
                "required": true,
                "data-source": "${data.subject_options}"
              },
              {
                "type": "TextInput",
                "name": "chapter",
                "label": "Chapter (optional)",
                "required": false,
                "helper-text": "e.g. Ch 3: Numbers"
              },
              {
                "type": "TextInput",
                "name": "page_ranges",
                "label": "Page range",
                "required": true,
                "helper-text": "e.g. 10-15 or 10-15, 20",
                "input-type": "text"
              },
              {
                "type": "RadioButtonsGroup",
                "name": "output_format",
                "label": "File format",
                "required": true,
                "data-source": "${data.output_format_options}"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "spec_submit",
                    "generation_type": "${form.generation_type}",
                    "grade": "${form.grade}",
                    "subject": "${form.subject}",
                    "chapter": "${form.chapter}",
                    "page_ranges": "${form.page_ranges}",
                    "output_format": "${form.output_format}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SEEN_UNSEEN",
      "title": "Content source",
      "data": {
        "spec_summary": {
          "type": "string",
          "__example__": "Grade 4 · English · Pages 10-15"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Seen, unseen, or both?"
          },
          {
            "type": "TextBody",
            "text": "${data.spec_summary}"
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "content_source",
                "label": "Where do the questions come from?",
                "required": true,
                "data-source": [
                  {
                    "id": "seen",
                    "title": "Seen",
                    "description": "Straight from the textbook"
                  },
                  {
                    "id": "unseen",
                    "title": "Unseen",
                    "description": "New questions on the same content"
                  },
                  {
                    "id": "both",
                    "title": "Both",
                    "description": "Mix seen and unseen"
                  }
                ]
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "pick_source",
                    "content_source": "${form.content_source}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "OBJ_SUBJ",
      "title": "Question category",
      "data": {
        "spec_summary": {
          "type": "string",
          "__example__": "Grade 4 · English · Pages 10-15"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Objective, Subjective, or both?"
          },
          {
            "type": "TextBody",
            "text": "${data.spec_summary}"
          },
          {
            "type": "TextCaption",
            "text": "Tick one, or tick both to mix them in the same paper."
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "CheckboxGroup",
                "name": "categories",
                "label": "Categories",
                "required": true,
                "min-selected-items": 1,
                "max-selected-items": 2,
                "data-source": [
                  {
                    "id": "objective",
                    "title": "Objective",
                    "description": "MCQs, MSQs, Fill in the Blanks, T/F, Match the Column, …"
                  },
                  {
                    "id": "subjective",
                    "title": "Subjective",
                    "description": "Brief Answers, Word Problems, Comprehension, Essay Writing, …"
                  }
                ]
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "pick_category",
                    "categories": "${form.categories}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "PICK_TYPES",
      "title": "Question types",
      "data": {
        "spec_summary": {
          "type": "string",
          "__example__": "Grade 4 · English · Pages 10-15"
        },
        "type_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "MCQs",
              "title": "MCQs"
            },
            {
              "id": "Fill in the Blanks",
              "title": "Fill in the Blanks"
            }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Pick question types"
          },
          {
            "type": "TextBody",
            "text": "${data.spec_summary}"
          },
          {
            "type": "TextCaption",
            "text": "Tick the types you want. You'll set how many of each on the next screen."
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "CheckboxGroup",
                "name": "question_types",
                "label": "Types",
                "required": true,
                "min-selected-items": 1,
                "data-source": "${data.type_options}",
                "max-selected-items": 10
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "pick_types",
                    "question_types": "${form.question_types}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SET_COUNTS",
      "title": "How many?",
      "data": {
        "spec_summary": {
          "type": "string",
          "__example__": "Grade 4 · English · Pages 10-15"
        },
        "picked_summary": {
          "type": "string",
          "__example__": "2 types: MCQs, True / False"
        },
        "default_count": {
          "type": "string",
          "__example__": "3"
        },
        "label_1": {
          "type": "string",
          "__example__": "MCQs — how many?"
        },
        "show_1": {
          "type": "boolean",
          "__example__": true
        },
        "label_2": {
          "type": "string",
          "__example__": ""
        },
        "show_2": {
          "type": "boolean",
          "__example__": true
        },
        "label_3": {
          "type": "string",
          "__example__": ""
        },
        "show_3": {
          "type": "boolean",
          "__example__": false
        },
        "label_4": {
          "type": "string",
          "__example__": ""
        },
        "show_4": {
          "type": "boolean",
          "__example__": false
        },
        "label_5": {
          "type": "string",
          "__example__": ""
        },
        "show_5": {
          "type": "boolean",
          "__example__": false
        },
        "label_6": {
          "type": "string",
          "__example__": ""
        },
        "show_6": {
          "type": "boolean",
          "__example__": false
        },
        "label_7": {
          "type": "string",
          "__example__": ""
        },
        "show_7": {
          "type": "boolean",
          "__example__": false
        },
        "label_8": {
          "type": "string",
          "__example__": ""
        },
        "show_8": {
          "type": "boolean",
          "__example__": false
        },
        "label_9": {
          "type": "string",
          "__example__": ""
        },
        "show_9": {
          "type": "boolean",
          "__example__": false
        },
        "label_10": {
          "type": "string",
          "__example__": ""
        },
        "show_10": {
          "type": "boolean",
          "__example__": false
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "How many of each?"
          },
          {
            "type": "TextBody",
            "text": "${data.picked_summary}"
          },
          {
            "type": "TextCaption",
            "text": "Leave blank to use the default of ${data.default_count}."
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "TextInput",
                "name": "count_1",
                "label": "${data.label_1}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_1}",
                "helper-text": "Max 20."
              },
              {
                "type": "TextInput",
                "name": "count_2",
                "label": "${data.label_2}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_2}",
                "helper-text": "Max 20."
              },
              {
                "type": "TextInput",
                "name": "count_3",
                "label": "${data.label_3}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_3}",
                "helper-text": "Max 20."
              },
              {
                "type": "TextInput",
                "name": "count_4",
                "label": "${data.label_4}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_4}",
                "helper-text": "Max 20."
              },
              {
                "type": "TextInput",
                "name": "count_5",
                "label": "${data.label_5}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_5}",
                "helper-text": "Max 20."
              },
              {
                "type": "TextInput",
                "name": "count_6",
                "label": "${data.label_6}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_6}",
                "helper-text": "Max 20."
              },
              {
                "type": "TextInput",
                "name": "count_7",
                "label": "${data.label_7}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_7}",
                "helper-text": "Max 20."
              },
              {
                "type": "TextInput",
                "name": "count_8",
                "label": "${data.label_8}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_8}",
                "helper-text": "Max 20."
              },
              {
                "type": "TextInput",
                "name": "count_9",
                "label": "${data.label_9}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_9}",
                "helper-text": "Max 20."
              },
              {
                "type": "TextInput",
                "name": "count_10",
                "label": "${data.label_10}",
                "required": false,
                "input-type": "number",
                "visible": "${data.show_10}",
                "helper-text": "Max 20."
              },
              {
                "type": "Footer",
                "label": "Generate paper",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "generate",
                    "count_1": "${form.count_1}",
                    "count_2": "${form.count_2}",
                    "count_3": "${form.count_3}",
                    "count_4": "${form.count_4}",
                    "count_5": "${form.count_5}",
                    "count_6": "${form.count_6}",
                    "count_7": "${form.count_7}",
                    "count_8": "${form.count_8}",
                    "count_9": "${form.count_9}",
                    "count_10": "${form.count_10}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "title": "On the way",
      "terminal": true,
      "success": true,
      "data": {
        "message": {
          "type": "string",
          "__example__": "Making your assessment. We'll send the PDF when it's ready."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "On the way"
          },
          {
            "type": "TextBody",
            "text": "${data.message}"
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}