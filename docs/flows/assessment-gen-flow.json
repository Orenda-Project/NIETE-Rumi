{
  "version": "5.1",
  "data_api_version": "3.0",
  "routing_model": {
    "SPEC": ["QUESTIONS"],
    "QUESTIONS": ["SUCCESS"]
  },
  "screens": [
    {
      "id": "SPEC",
      "title": "New assessment",
      "data": {
        "grade_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [
            { "id": "1", "title": "Grade 1" },
            { "id": "2", "title": "Grade 2" },
            { "id": "3", "title": "Grade 3" },
            { "id": "4", "title": "Grade 4" },
            { "id": "5", "title": "Grade 5" }
          ]
        },
        "subject_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [
            { "id": "Eng", "title": "English" },
            { "id": "Maths", "title": "Maths" },
            { "id": "Urdu", "title": "Urdu" },
            { "id": "Science", "title": "Science" },
            { "id": "Islamiat", "title": "Islamiat" },
            { "id": "SST", "title": "Social Studies" },
            { "id": "GenK", "title": "General Knowledge" }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Assessment builder"
          },
          {
            "type": "TextSubheading",
            "text": "Pick what to test. We'll build the paper and send you a PDF."
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "generation_type",
                "label": "Type",
                "required": true,
                "data-source": [
                  { "id": "exam", "title": "Exam", "description": "A full graded paper" },
                  { "id": "class_assessment", "title": "Classroom practice", "description": "Quick in-class practice" }
                ]
              },
              {
                "type": "Dropdown",
                "name": "grade",
                "label": "Grade",
                "required": true,
                "data-source": "${data.grade_options}"
              },
              {
                "type": "Dropdown",
                "name": "subject",
                "label": "Subject",
                "required": true,
                "data-source": "${data.subject_options}"
              },
              {
                "type": "TextInput",
                "name": "chapter",
                "label": "Chapter (optional)",
                "required": false,
                "helper-text": "e.g. Ch 3: Numbers"
              },
              {
                "type": "TextInput",
                "name": "page_ranges",
                "label": "Page range",
                "required": true,
                "helper-text": "e.g. 10-15 or 10-15, 20",
                "input-type": "text"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "spec_submit",
                    "generation_type": "${form.generation_type}",
                    "grade": "${form.grade}",
                    "subject": "${form.subject}",
                    "chapter": "${form.chapter}",
                    "page_ranges": "${form.page_ranges}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "QUESTIONS",
      "title": "Questions",
      "data": {
        "spec_summary": {
          "type": "string",
          "__example__": "Grade 4 English · Pages 10-15"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "What kind of questions?"
          },
          {
            "type": "TextBody",
            "text": "${data.spec_summary}"
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "content_source",
                "label": "From the textbook (seen) or new (unseen)?",
                "required": true,
                "data-source": [
                  { "id": "seen", "title": "Seen", "description": "Questions from the textbook" },
                  { "id": "unseen", "title": "Unseen", "description": "New questions on the same content" }
                ]
              },
              {
                "type": "CheckboxGroup",
                "name": "question_types",
                "label": "Question types",
                "required": true,
                "min-selected-items": 1,
                "data-source": [
                  { "id": "MCQs", "title": "MCQs" },
                  { "id": "Fill in the Blanks", "title": "Fill in the Blanks" },
                  { "id": "Brief Answers", "title": "Brief Answers" }
                ]
              },
              {
                "type": "TextInput",
                "name": "count_mcqs",
                "label": "How many MCQs?",
                "required": false,
                "helper-text": "0 to skip",
                "input-type": "number"
              },
              {
                "type": "TextInput",
                "name": "count_fill",
                "label": "How many Fill in the Blanks?",
                "required": false,
                "helper-text": "0 to skip",
                "input-type": "number"
              },
              {
                "type": "TextInput",
                "name": "count_brief",
                "label": "How many Brief Answers?",
                "required": false,
                "helper-text": "0 to skip",
                "input-type": "number"
              },
              {
                "type": "Footer",
                "label": "Generate",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "generate",
                    "content_source": "${form.content_source}",
                    "question_types": "${form.question_types}",
                    "count_mcqs": "${form.count_mcqs}",
                    "count_fill": "${form.count_fill}",
                    "count_brief": "${form.count_brief}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "title": "On the way",
      "terminal": true,
      "success": true,
      "data": {
        "message": {
          "type": "string",
          "__example__": "Making your assessment. We'll send the PDF when it's ready."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "On the way"
          },
          {
            "type": "TextBody",
            "text": "${data.message}"
          },
          {
            "type": "Footer",
            "label": "Done",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
