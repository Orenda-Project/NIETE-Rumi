{
  "version": "5.1",
  "data_api_version": "3.0",
  "routing_model": {
    "TYPE_SELECT":         ["GRADE_SUBJECT"],
    "GRADE_SUBJECT":       ["CHAPTERS"],
    "CHAPTERS":            ["QUESTION_TYPES"],
    "QUESTION_TYPES":      ["SUCCESS"]
  },
  "screens": [
    {
      "id": "TYPE_SELECT",
      "title": "New exam",
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "What kind of exam?"
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "exam_type",
                "label": "Exam type",
                "required": true,
                "data-source": [
                  { "id": "WEEKLY", "title": "Weekly test",  "description": "1-2 chapters, ~40 min" },
                  { "id": "TERM",   "title": "Term exam",     "description": "Multiple chapters, ~2 hours" }
                ]
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "select_type",
                    "exam_type": "${form.exam_type}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "GRADE_SUBJECT",
      "title": "Grade & subject",
      "data": {
        "grade_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "5", "title": "Grade Five" }]
        },
        "subject_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "Math", "title": "Math" }]
        },
        "language_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "en", "title": "English" }, { "id": "ur", "title": "Urdu" }]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Which class?"
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "Dropdown",
                "name": "grade",
                "label": "Grade",
                "required": true,
                "data-source": "${data.grade_options}"
              },
              {
                "type": "Dropdown",
                "name": "subject",
                "label": "Subject",
                "required": true,
                "data-source": "${data.subject_options}"
              },
              {
                "type": "Dropdown",
                "name": "language",
                "label": "Language",
                "required": true,
                "data-source": "${data.language_options}"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "select_grade_subject",
                    "grade":    "${form.grade}",
                    "subject":  "${form.subject}",
                    "language": "${form.language}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "CHAPTERS",
      "title": "Chapters",
      "data": {
        "chapter_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "1", "title": "Ch 1: Numbers" }]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Which chapters?"
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "CheckboxGroup",
                "name": "chapters",
                "label": "Select 1 or more",
                "required": true,
                "data-source": "${data.chapter_options}"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "select_chapters",
                    "chapters": "${form.chapters}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "QUESTION_TYPES",
      "title": "Question types",
      "data": {
        "question_type_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [
            { "id": "mcq",           "title": "MCQ" },
            { "id": "short_answer",  "title": "Short Answer" },
            { "id": "long_answer",   "title": "Long Answer" },
            { "id": "fill_blanks",   "title": "Fill in the Blanks" },
            { "id": "true_false",    "title": "True/False" },
            { "id": "match_columns", "title": "Match the Columns" },
            { "id": "comprehension", "title": "Comprehension" }
          ]
        },
        "question_type_defaults": {
          "type": "array",
          "items": { "type": "string" },
          "__example__": [
            "mcq", "short_answer", "long_answer", "fill_blanks",
            "true_false", "match_columns", "comprehension"
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Which question types?"
          },
          {
            "type": "TextBody",
            "text": "All 7 are included by default. Uncheck any you don't want."
          },
          {
            "type": "Form",
            "name": "form",
            "init-values": {
              "question_types": "${data.question_type_defaults}"
            },
            "children": [
              {
                "type": "CheckboxGroup",
                "name": "question_types",
                "label": "Question types",
                "required": true,
                "min-selected-items": 1,
                "max-selected-items": 7,
                "data-source": "${data.question_type_options}"
              },
              {
                "type": "Footer",
                "label": "Generate exam",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "_action": "generate",
                    "question_types": "${form.question_types}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "terminal": true,
      "success": true,
      "title": "On its way",
      "data": {
        "message": { "type": "string", "__example__": "Making your exam…" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextBody",
            "text": "${data.message}"
          },
          {
            "type": "Footer",
            "label": "Close",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
