# ============================================================================
# Rumi Platform — Environment Configuration
# ============================================================================
#
# HOW THIS WORKS (read this first — also true for your AI setup agent):
#
#   1. Copy this file:            cp .env.template .env
#   2. Fill in the REQUIRED block below (8 values). That alone boots the bot
#      with AI chat + registration.
#   3. Features turn on by PRESENCE. Set a feature's keys and that feature
#      switches on automatically — there is no master "enable" flag to flip.
#      Leave a feature's keys blank and that feature stays off cleanly (the
#      bot will never crash because a key is missing; it just won't offer
#      that feature). Each optional block below says exactly which keys
#      switch it on.
#   4. Verify what you configured:   npm run doctor
#      (prints a green/red matrix of every service and which features are live)
#
# Any value shown as CHANGEME, your-..., or a placeholder URL MUST be replaced.
# Never commit your real .env — only this template is tracked (.env is gitignored).
#
# ============================================================================
# ███  REQUIRED — the bot will not start without these 8  ███████████████████
# ============================================================================

# Node environment: production | development | test
NODE_ENV=production

# HTTP port for the bot server
PORT=3000

# --- Database (Supabase) — create a free project at https://supabase.com ----

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase SERVICE ROLE key (Settings → API → service_role). NOT the anon key.
SUPABASE_SERVICE_ROLE_KEY=CHANGEME-supabase-service-role-key

# --- AI / LLM — one key powers all text generation --------------------------

# Your OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=CHANGEME-sk-or-v1-your-openrouter-key

# --- Redis — job queue + session state --------------------------------------
# Use a managed Redis (Railway/Upstash) in production. Local dev can use the
# default below with a locally running Redis.
REDIS_URL=redis://localhost:6379

# --- WhatsApp — from Meta Business Manager (see docs/whatsapp-setup) ---------
# These four are filled by `npm run bootstrap:whatsapp`, or paste them manually.

# WhatsApp Cloud API access token (a permanent system-user token)
WHATSAPP_TOKEN=CHANGEME-whatsapp-token

# WhatsApp phone number ID (NOT the phone number itself)
PHONE_NUMBER_ID=CHANGEME-phone-number-id

# Webhook verify token — you invent this; any random string, must match Meta config
WEBHOOK_VERIFY_TOKEN=CHANGEME-pick-any-random-string

# WhatsApp Business Account (WABA) ID
WABA_ID=CHANGEME-waba-id

# ============================================================================
# ███  OPTIONAL — set a block's keys to switch that feature on  █████████████
# ============================================================================

# --- LLM: advanced (optional) -----------------------------------------------

# LLM provider: 'openrouter' (default, recommended) or 'openai' (direct)
LLM_PROVIDER=openrouter

# Direct OpenAI API key — only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=

# Override the default model (default: openai/gpt-4o via OpenRouter)
LLM_MODEL=openai/gpt-4o

# App URL used for OpenRouter's HTTP-Referer header (optional)
APP_URL=https://your-app.up.railway.app

# --- Region (optional) -------------------------------------------------------
# This deployment's region. Per-region behaviour (which LP paths, coaching
# framework, languages) is driven by the region_features DB table — set a row
# per region; no code changes needed. Leave as 'default' for the generic setup.
DEFAULT_REGION=default

# --- ENABLES: Voice notes in (transcription) — Soniox -----------------------
# Set this to let teachers send voice notes the bot understands (multi-language
# STT: Urdu, Balochi, Sindhi, Pashto, ...). Also required for reading assessment
# and coaching, which both consume audio. Get a key at https://soniox.com
SONIOX_API_KEY=

# --- ENABLES: Spoken replies (text-to-speech) — ElevenLabs ------------------
# Set this to let the bot reply with voice. Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=
# Default English voice ID (a sensible default is provided)
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9
# Additional-language voice IDs (optional — defaults exist)
# ELEVENLABS_VOICE_ID_ES=your-spanish-voice-id
# ELEVENLABS_VOICE_ID_AR=your-arabic-voice-id

# --- ENABLES: Urdu/regional TTS — Uplift (optional alternative voice) --------
UPLIFT_API_KEY=
# UPLIFT_VOICE_ID_UR=your-urdu-voice-id
# UPLIFT_VOICE_ID_SD=your-sindhi-voice-id
# UPLIFT_VOICE_ID_BAL=your-balochi-voice-id

# --- ENABLES: Pronunciation scoring in reading assessment — Azure Speech ----
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- ENABLES: Lesson-plan & presentation generation — Gamma -----------------
# Set this to turn on the lesson-plan generator. Get a key at https://gamma.app
GAMMA_API_KEY=

# --- Optional: Media Assets --------------------------------------------------
# These are WhatsApp media IDs for stickers/videos (uploaded to WhatsApp CDN)
# Leave blank to skip — bot works without them

LOADING_STICKER_MEDIA_ID=
REGISTRATION_SUCCESS_STICKER_MEDIA_ID=
LISTENING_ANIMATION_MEDIA_ID=
PEDAGOGICAL_ANALYSIS_MEDIA_ID=
MENU_IMAGE_MEDIA_ID=
REGISTRATION_VIDEO_MEDIA_ID=

# --- Optional: Staging / Testing -----------------------------------------------

STAGING_PHONE_NUMBER=
TEST_PHONE_NUMBER=

# Set to 'true' when running in staging environment (used by template scripts)
# STAGING=false

# Set to 'true' to enable offline replay mode for lesson plan extraction
# OFFLINE_REPLAY=false

# --- Optional: WhatsApp Flows ------------------------------------------------

READING_ASSESSMENT_FLOW_ID=
ATTENDANCE_SETUP_FLOW_ID=
ATTENDANCE_MARKING_FLOW_ID=
REGISTRATION_FLOW_ID=
EXAM_CHECKER_STUDENTS_FLOW_ID=

# --- Optional: BullMQ Worker --------------------------------------------------
# Configuration for background job processing

QUEUE_NAME=rumi-jobs
WORKER_CONCURRENCY=3
WORKER_PORT=3001

# Graceful shutdown timeout in ms for workers (default: 30000)
# GRACEFUL_SHUTDOWN_TIMEOUT=30000

# Temp directory for file processing (default: /tmp)
# TEMP_DIR=/tmp

# --- Optional: WhatsApp Flow Encryption --------------------------------------
# Required if using WhatsApp Flows (reading assessment, attendance)
# Provide either PEM or Base64-encoded format

FLOW_PRIVATE_KEY=
FLOW_PUBLIC_KEY=
FLOW_PRIVATE_KEY_B64=
FLOW_PUBLIC_KEY_B64=

# --- ENABLES: Educational video generation ----------------------------------
