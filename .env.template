# ============================================================================
# Rumi Platform - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked [REQUIRED]. Others are optional/tier-dependent.
#
# Tier 1 (Minimal): Only needs REQUIRED + OpenRouter
# Tier 2 (Recommended): Also needs Soniox
# Tier 3 (Full): Also needs Azure Speech, ElevenLabs, Gamma
# ============================================================================

# --- Core Settings -----------------------------------------------------------

# [REQUIRED] Node environment (production, development, test)
NODE_ENV=production

# [REQUIRED] HTTP port for the bot server
PORT=3000

# [REQUIRED] Feature tier: minimal, recommended, or full
RUMI_TIER=minimal

# --- Database (Supabase) ----------------------------------------------------

# [REQUIRED] Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Your Supabase service role key (NOT the anon key)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AI / LLM Provider ------------------------------------------------------

# [REQUIRED] LLM provider: 'openrouter' (default) or 'openai' (direct)
LLM_PROVIDER=openrouter

# [REQUIRED for openrouter] OpenRouter API key (get at https://openrouter.ai/keys)
# One key provides access to GPT-4o, Claude, Gemini, and 500+ other models
OPENROUTER_API_KEY=sk-or-v1-...your-openrouter-key

# [Optional] Direct OpenAI API key (only if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# [Optional] Override default LLM model (default: openai/gpt-4o via OpenRouter)
LLM_MODEL=openai/gpt-4o

# [Optional] App URL for OpenRouter HTTP-Referer header
APP_URL=https://your-app.up.railway.app

# --- Redis / Job Queue -------------------------------------------------------

# [REQUIRED] Redis connection URL (auto-set by Railway if using their Redis plugin)
REDIS_URL=redis://localhost:6379

# --- WhatsApp Configuration --------------------------------------------------

# [REQUIRED] WhatsApp API access token (from Meta Business Manager)
WHATSAPP_TOKEN=your-whatsapp-token

# [REQUIRED] WhatsApp phone number ID
PHONE_NUMBER_ID=your-phone-number-id

# [REQUIRED] Webhook verification token (you choose this — any random string)
WEBHOOK_VERIFY_TOKEN=your-random-verify-token

# [REQUIRED] WhatsApp Business Account ID
WABA_ID=your-waba-id

# --- Tier 2: Recommended (Speech-to-Text) -----------------------------------

# [Tier 2+] Soniox API key for multi-language STT (Urdu, Balochi, Sindhi, Pashto)
SONIOX_API_KEY=

# --- Tier 3: Full (All Features) --------------------------------------------

# [Tier 3] ElevenLabs API key for text-to-speech voice responses
ELEVENLABS_API_KEY=

# [Tier 3] ElevenLabs voice ID (default: Jessica voice for English)
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9

# [Tier 3] Uplift API key for Urdu/regional language TTS
UPLIFT_API_KEY=

# [Tier 3] Azure Speech API key for pronunciation assessment
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# [Tier 3] Gamma API key for lesson plan/presentation generation
GAMMA_API_KEY=

# --- Optional: Media Assets --------------------------------------------------
# These are WhatsApp media IDs for stickers/videos (uploaded to WhatsApp CDN)
# Leave blank to skip — bot works without them

LOADING_STICKER_MEDIA_ID=
REGISTRATION_SUCCESS_STICKER_MEDIA_ID=
LISTENING_ANIMATION_MEDIA_ID=
PEDAGOGICAL_ANALYSIS_MEDIA_ID=
MENU_IMAGE_MEDIA_ID=
REGISTRATION_VIDEO_MEDIA_ID=

# --- Optional: Staging / Testing -----------------------------------------------

STAGING_PHONE_NUMBER=

# --- Optional: WhatsApp Flows ------------------------------------------------

READING_ASSESSMENT_FLOW_ID=
ATTENDANCE_SETUP_FLOW_ID=
ATTENDANCE_MARKING_FLOW_ID=

# --- Optional: BullMQ Worker --------------------------------------------------
# Configuration for background job processing

QUEUE_NAME=rumi-jobs
WORKER_CONCURRENCY=3
WORKER_PORT=3001

# --- Optional: WhatsApp Flow Encryption --------------------------------------
# Required if using WhatsApp Flows (reading assessment, attendance)

FLOW_PRIVATE_KEY=
FLOW_PUBLIC_KEY=

# --- Optional: Video Generation -----------------------------------------------
# Required for Tier 3 (Full) video generation feature

VIDEO_GENERATION_ENABLED=false
VIDEO_WATERMARK_ENABLED=true
VIDEO_DAILY_LIMIT=5

# --- Optional: Dashboard Auth ------------------------------------------------
# For the Observability Dashboard login system

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
DASHBOARD_PORT=3002
DASHBOARD_URL=
BROADCAST_PASSWORD=

# --- Optional: MMS-ASR Service (Regional Pakistani Languages) ----------------
# Self-hosted speech recognition for Balochi, Sindhi, Pashto via Modal.com

MMS_SERVICE_URL=
MMS_TIMEOUT_MS=60000
MMS_API_KEY=

# --- Optional: Cloud Storage (Cloudflare R2) ----------------------------------
# For storing coaching audio, reading recordings, etc.

CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- Optional: Logging / Observability ---------------------------------------

AXIOM_TOKEN=
AXIOM_DATASET=

# --- Optional: Branding Override ---------------------------------------------
# Override default branding (defaults to "Rumi" if not set)

BOT_NAME=
ORG_NAME=
SUPPORT_CONTACT=

# --- Optional: URLs & Domains ------------------------------------------------
# Used by portal invitations, video watermarks, broadcast validation, etc.

# Portal URL for teacher-facing web portal (used in WhatsApp messages)
PORTAL_URL=https://your-portal-domain.com

# Public assets base URL (for video/media links sent in WhatsApp)
ASSETS_BASE_URL=https://your-domain.com/assets

# Website URL (for dashboard CORS and redirects)
WEBSITE_URL=https://your-website.com

# Bot domain for broadcast URL validation (just the domain, e.g. example.com)
BOT_DOMAIN=example.com

# Video watermark text (shown on generated videos)
VIDEO_WATERMARK_TEXT=Created with Rumi

# WhatsApp display name (used by deployment scripts)
WHATSAPP_DISPLAY_NAME=Rumi - AI Teaching Assistant

# --- Optional: GitHub Integration ---------------------------------------------
# For BYOF (Bring Your Own Fork) and dashboard GitHub features

GITHUB_ORG=
GITHUB_TOKEN=

# --- Optional: Email Service (Resend) ----------------------------------------
# For portal invitation and password reset emails

RESEND_API_KEY=
EMAIL_FROM=noreply@your-domain.com

# --- Optional: Dashboard Database ---------------------------------------------
# Only needed if running the Observability Dashboard (Phase 2)

SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres
DB_POOL_SIZE=20
DB_POOL_MIN=2

# --- Optional: Dashboard → Bot API Communication ----------------------------

MAIN_BOT_URL=
INTERNAL_API_KEY=

# --- Optional: Notification WhatsApp (BYOF Feature) -------------------------
# Separate WhatsApp number for sending dashboard notifications

NOTIFICATION_PHONE_ID=
NOTIFICATION_ACCESS_TOKEN=

# --- Optional: Dashboard JWT Secrets ------------------------------------------

JWT_SECRET=your-random-jwt-secret
PORTAL_JWT_SECRET=your-random-portal-jwt-secret

# --- Optional: Meta App Configuration ----------------------------------------
# Required for uploading media assets to WhatsApp via Meta Graph API

META_APP_ID=

# --- Optional: Dashboard AI (Anthropic) -------------------------------------
# Used by BYOF agent and billing analysis in the dashboard

ANTHROPIC_API_KEY=

# --- Optional: Rate Limiting -------------------------------------------------

RATE_LIMIT_BYPASS_NUMBERS=

# --- Optional: Logging Configuration -----------------------------------------

LOG_LEVEL=info

# --- Optional: Database (Direct PostgreSQL) -----------------------------------
# Only needed if running dashboard with direct DB access (instead of Supabase client)

DATABASE_URL=

# --- Optional: AWS Textract (Exam Checking OCR) -------------------------------
# Required for exam checker feature (auto-grading scanned answer sheets)

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Optional: Exam Checker AI Models ----------------------------------------
# Additional AI providers used by the exam checker feature

MISTRAL_API_KEY=
DATALAB_API_KEY=
GEMINI_API_KEY=

# --- Optional: Facebook Graph API Version ------------------------------------
# Override the default Graph API version used for WhatsApp API calls

GRAPH_API_VERSION=v21.0

# --- Optional: Staging Configuration -----------------------------------------
# For running a separate staging environment

META_APP_ID_STAGING=
STAGING_WABA_ID=
