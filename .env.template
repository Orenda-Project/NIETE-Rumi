# --- Optional: STEPS BigQuery attendance export -------------------------------
# Nightly worker (bot/workers/attendance-bigquery-export.worker.js) rolls
# yesterday's teacher_attendance_records into the STEPS BigQuery warehouse.
# Feature is presence-gated on GOOGLE_SERVICE_ACCOUNT_PATH + BIGQUERY_STEPS_PROJECT_ID.
#
# GOOGLE_SERVICE_ACCOUNT_PATH  — absolute path to the GCP service account JSON
#                                key file. The service account must have
#                                BigQuery Data Editor + BigQuery Job User on
#                                the target project.
# BIGQUERY_STEPS_PROJECT_ID    — target GCP project (e.g. `my-warehouse-project`).
# BIGQUERY_STEPS_DATASET       — dataset name. Default: `steps`.
# BIGQUERY_STEPS_TABLE         — table name.   Default: `attendance`.
# BIGQUERY_STEPS_AUTO_CREATE_TABLE
#                              — governs whether ensureTable() actually issues
#                                CREATE TABLE IF NOT EXISTS on first run.
#                                Unset OR truthy ("true"/"1"/"yes") → auto-create
#                                is ENABLED (default; convenient for
#                                dev/staging first-boot).
#                                "false"/"0"/"no" → auto-create is DISABLED and
#                                the DDL step short-circuits with a log line.
#                                Prod convention: set to `false` and run
#                                scripts/bigquery-steps-attendance-ddl.sql by
#                                hand so schema creation is a human-reviewed
#                                step (per TASK-133 review). The CREATE TABLE
#                                IF NOT EXISTS remains as a harmless backstop.
#
# The DDL for the target table lives at scripts/bigquery-steps-attendance-ddl.sql;
# the worker also runs CREATE TABLE IF NOT EXISTS on first execution unless
# BIGQUERY_STEPS_AUTO_CREATE_TABLE is set to false.
# See docs/attendance-bigquery-sync.md for the ops runbook.
GOOGLE_SERVICE_ACCOUNT_PATH=
BIGQUERY_STEPS_PROJECT_ID=
BIGQUERY_STEPS_DATASET=
BIGQUERY_STEPS_TABLE=
BIGQUERY_STEPS_AUTO_CREATE_TABLE=
