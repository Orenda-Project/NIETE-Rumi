<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Set Up Your Account - Rumi Observability Portal</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" type="image/png" href="/images/rumi-logo.png">
</head>
<body class="min-h-screen p-4" style="background: var(--gradient-subtle);">
  <div class="flex flex-col items-center justify-center min-h-screen">
    <div class="card-primary p-8 w-full max-w-md">
      <div class="text-center mb-8">
        <div class="flex justify-center mb-4">
          <img src="/images/rumi-logo.png" alt="Rumi logo" class="w-16 h-16 object-contain">
        </div>
        <h1 class="text-3xl font-light text-foreground mb-2">Rumi</h1>
        <p class="text-muted-foreground">
          <% if (invitation) { %>
            Set up your account to get started
          <% } else { %>
            Account Setup
          <% } %>
        </p>
      </div>

      <% if (error) { %>
        <div class="status-error border rounded-lg px-4 py-3 mb-6" role="alert">
          <p class="font-medium text-sm"><%= error %></p>
        </div>
      <% } %>

      <% if (invitation) { %>
        <!-- Invitation Info -->
        <div class="mb-6 p-4 bg-muted/50 rounded-lg border border-border">
          <p class="text-sm text-muted-foreground mb-2">Account Details</p>
          <p class="text-sm font-medium text-foreground">Email: <%= invitation.email %></p>
          <p class="text-sm font-medium text-foreground mt-1">Role:
            <%
              const roleDisplay = {
                'partner_admin': 'Partner Admin',
                'partner_viewer': 'Partner Viewer',
                'admin': 'Admin',
                'super_admin': 'Super Admin'
              };
            %>
            <span class="<%= invitation.role.includes('admin') ? 'text-primary' : 'text-green-600' %>">
              <%= roleDisplay[invitation.role] || invitation.role %>
            </span>
          </p>
          <% if (invitation.inviter_username) { %>
            <p class="text-xs text-muted-foreground mt-3">Invited by <%= invitation.inviter_username %></p>
          <% } %>
        </div>

        <form action="/observability/setup-password" method="POST" class="space-y-6">
          <input type="hidden" name="token" value="<%= token %>">

          <!-- Username -->
          <div>
            <label for="username" class="block text-sm font-medium text-foreground mb-2">
              Choose Username
            </label>
            <input
              id="username"
              name="username"
              type="text"
              required
              minlength="3"
              maxlength="20"
              pattern="[a-zA-Z0-9_-]+"
              class="input-field"
              placeholder="Choose a username"
            >
            <p class="mt-1 text-xs text-muted-foreground">
              Letters, numbers, underscores and hyphens only (3-20 characters)
            </p>
          </div>

          <!-- Password -->
          <div>
            <label for="password" class="block text-sm font-medium text-foreground mb-2">
              Create Password
            </label>
            <input
              id="password"
              name="password"
              type="password"
              required
              minlength="8"
              class="input-field"
              placeholder="Create a secure password"
            >
            <p class="mt-1 text-xs text-muted-foreground">
              Minimum 8 characters with uppercase, lowercase, and number
            </p>
          </div>

          <!-- Confirm Password -->
          <div>
            <label for="confirmPassword" class="block text-sm font-medium text-foreground mb-2">
              Confirm Password
            </label>
            <input
              id="confirmPassword"
              name="confirmPassword"
              type="password"
              required
              minlength="8"
              class="input-field"
              placeholder="Confirm your password"
            >
            <p class="mt-1 text-xs" id="password-match-status"></p>
          </div>

          <!-- Role Information -->
          <div class="bg-primary/5 rounded-lg p-4 border border-primary/20">
            <h4 class="text-sm font-medium text-foreground mb-2">Your Access Level:
              <% const roleLabels = {
                'partner_admin': 'Partner Admin',
                'partner_viewer': 'Partner Viewer',
                'admin': 'Admin',
                'super_admin': 'Super Admin'
              }; %>
              <span class="text-primary"><%= roleLabels[invitation.role] || invitation.role %></span>
            </h4>
            <% if (invitation.role === 'partner_admin') { %>
              <ul class="text-xs text-muted-foreground space-y-1">
                <li>• Access to assigned schools/districts analytics</li>
                <li>• View coaching sessions and lesson plans</li>
                <li>• Invite and manage partner viewers</li>
                <li>• Access to reports within your scope</li>
              </ul>
            <% } else if (invitation.role === 'partner_viewer') { %>
              <ul class="text-xs text-muted-foreground space-y-1">
                <li>• View all dashboard analytics and reports</li>
                <li>• Access to conversation history</li>
                <li>• Read-only access to all features</li>
              </ul>
            <% } else if (invitation.role === 'admin' || invitation.role === 'super_admin') { %>
              <ul class="text-xs text-muted-foreground space-y-1">
                <li>• Full access to all dashboard features</li>
                <li>• Ability to invite and manage other users</li>
                <li>• Access to system settings</li>
              </ul>
            <% } else { %>
              <ul class="text-xs text-muted-foreground space-y-1">
                <li>• View dashboard analytics</li>
                <li>• Access to reports</li>
              </ul>
            <% } %>
          </div>

          <button type="submit" id="submitBtn" class="w-full btn-primary py-3">
            Complete Setup
          </button>
        </form>
      <% } else { %>
        <!-- Error state when token is invalid -->
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <h3 class="mt-4 text-lg font-medium text-foreground">Invalid or Expired Invitation</h3>
          <p class="mt-2 text-sm text-muted-foreground">
            This invitation link is invalid or has expired. Please contact your administrator for a new invitation.
          </p>
          <div class="mt-6">
            <a href="/observability/login" class="text-primary hover:text-primary/80 text-sm font-medium">
              Go to Login →
            </a>
          </div>
        </div>
      <% } %>

      <div class="mt-8 text-center text-sm text-muted-foreground">
        <p>Rumi - AI Teaching Assistant</p>
      </div>
    </div>
  </div>

  <% if (invitation) { %>
    <script>
      // Username validation
      const usernameInput = document.getElementById('username');
      usernameInput.addEventListener('input', function() {
        const value = this.value;
        const valid = /^[a-zA-Z0-9_-]+$/.test(value);
        if (!valid && value.length > 0) {
          this.setCustomValidity('Username can only contain letters, numbers, underscores, and hyphens');
        } else {
          this.setCustomValidity('');
        }
      });

      // Password match validation
      const password = document.getElementById('password');
      const confirmPassword = document.getElementById('confirmPassword');
      const matchStatus = document.getElementById('password-match-status');
      const submitBtn = document.getElementById('submitBtn');

      function checkPasswordMatch() {
        if (confirmPassword.value === '') {
          matchStatus.textContent = '';
          matchStatus.className = 'mt-1 text-xs';
          return;
        }

        if (password.value === confirmPassword.value) {
          matchStatus.textContent = '✓ Passwords match';
          matchStatus.className = 'mt-1 text-xs text-green-600';
          submitBtn.disabled = false;
        } else {
          matchStatus.textContent = '✗ Passwords do not match';
          matchStatus.className = 'mt-1 text-xs text-red-600';
          submitBtn.disabled = true;
        }
      }

      password.addEventListener('keyup', checkPasswordMatch);
      confirmPassword.addEventListener('keyup', checkPasswordMatch);
    </script>
  <% } %>
</body>
</html>
