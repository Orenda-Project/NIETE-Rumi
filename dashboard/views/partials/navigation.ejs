<!-- Navigation Component with Rumi Design System -->
<%
  // Compute isAdmin with fallback for backward compatibility
  // Works whether isAdmin is passed explicitly or comes from res.locals
  const adminAccess = (typeof isAdmin !== 'undefined' && isAdmin) ||
                      (userRole === 'admin' || userRole === 'super_admin');
%>
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex items-center">
        <!-- Logo -->
        <div class="flex-shrink-0 flex items-center gap-3">
          <img src="/images/rumi-logo.png" alt="Rumi logo" class="w-8 h-8 object-contain">
          <span class="text-xl font-medium text-gray-900">Rumi Observability</span>
        </div>

        <!-- Main Navigation with Dropdowns -->
        <div class="hidden sm:ml-8 sm:flex sm:space-x-1 sm:items-center">

          <!-- Analytics Dropdown -->
          <div class="relative group">
            <button class="border-transparent text-gray-600 hover:text-gray-900 hover:bg-gray-50 inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors">
              Analytics
              <svg class="ml-1 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </button>
            <div class="hidden group-hover:block absolute left-0 top-full pt-2 w-56 z-50">
              <div class="bg-white rounded-lg shadow-lg border border-gray-200">
              <div class="py-1">
                <a href="/observability/dashboard" class="<%= currentPage === 'dashboard' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    Dashboard Overview
                  </span>
                </a>
                <a href="/observability/sessions" class="<%= currentPage === 'sessions' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    Session Analytics
                  </span>
                </a>
                <a href="/observability/funnel" class="<%= currentPage === 'funnel' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
                    </svg>
                    Funnel Metrics
                  </span>
                </a>
                <a href="/observability/retention" class="<%= currentPage === 'retention' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/>
                    </svg>
                    Retention Analysis
                  </span>
                </a>
                <a href="/observability/ab-testing" class="<%= currentPage === 'ab-testing' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    A/B Testing
                  </span>
                </a>
                <div class="border-t border-gray-100 my-1"></div>
                <a href="/observability/ama" class="<%= currentPage === 'ama' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                    </svg>
                    AMA (Ask Me Anything)
                  </span>
                </a>
              </div>
              </div>
            </div>
          </div>

          <!-- User Management Dropdown -->
          <div class="relative group">
            <button class="border-transparent text-gray-600 hover:text-gray-900 hover:bg-gray-50 inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors">
              Users
              <svg class="ml-1 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </button>
            <div class="hidden group-hover:block absolute left-0 top-full pt-2 w-56 z-50">
              <div class="bg-white rounded-lg shadow-lg border border-gray-200">
              <div class="py-1">
                <a href="/observability/users" class="<%= currentPage === 'users' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    Users & Conversations
                  </span>
                </a>
                <a href="/observability/coaching" class="<%= currentPage === 'coaching' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                    </svg>
                    Coaching Sessions
                  </span>
                </a>
                <% if (userRole === 'super_admin') { %>
                <div class="border-t border-gray-100 my-1"></div>
                <a href="/observability/ama-chats" class="<%= currentPage === 'ama-chats' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    AMA Chats (Super Admin)
                  </span>
                </a>
                <% } %>
              </div>
              </div>
            </div>
          </div>

          <!-- Operations Dropdown -->
          <div class="relative group">
            <button class="border-transparent text-gray-600 hover:text-gray-900 hover:bg-gray-50 inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors">
              Operations
              <svg class="ml-1 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </button>
            <div class="hidden group-hover:block absolute left-0 top-full pt-2 w-56 z-50">
              <div class="bg-white rounded-lg shadow-lg border border-gray-200">
              <div class="py-1">
                <a href="/observability/api-health" class="<%= currentPage === 'api-health' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    API Health Monitor
                  </span>
                </a>
                <a href="/observability/release-notes" class="<%= currentPage === 'release-notes' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                    </svg>
                    Release Notes
                  </span>
                </a>
                <a href="/observability/schema" class="<%= currentPage === 'schema' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
                    </svg>
                    Database Schema
                  </span>
                </a>
                <div class="border-t border-gray-100 my-1"></div>
                <a href="/observability/videos" class="<%= currentPage === 'videos' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                    </svg>
                    AI Videos
                  </span>
                </a>
                <a href="/observability/byof" class="<%= currentPage === 'byof' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>
                    </svg>
                    The Forge
                  </span>
                </a>
                <% if (adminAccess) { %>
                <div class="border-t border-gray-100 my-1"></div>
                <a href="/observability/broadcast" class="<%= currentPage === 'broadcast' || currentPage === 'broadcast-history' ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2 text-sm">
                  <span class="flex items-center">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                    </svg>
                    Broadcast (Admin)
                  </span>
                </a>
                <% } %>
              </div>
              </div>
            </div>
          </div>

          <!-- Admin Section (Internal Roles Only) -->
          <% if (userRole === 'super_admin') { %>
            <!-- Super Admin: Full Admin + Settings -->
            <a href="/observability/admin/users" class="<%= currentPage === 'admin-users' || currentPage === 'admin-invitations' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50' %> inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors" title="User & Partner Management">
              <svg class="mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
              Admin
            </a>
            <a href="/observability/settings" class="<%= currentPage === 'settings' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50' %> inline-flex items-center p-2 rounded-md transition-colors" title="Settings">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </a>
          <% } else if (userRole === 'admin' || userRole === 'viewer') { %>
            <!-- Admin/Viewer: Users (scope management) + Invites -->
            <a href="/observability/admin/users" class="<%= currentPage === 'admin-users' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50' %> inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors" title="User & Scope Management">
              <svg class="mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
              Users
            </a>
            <a href="/observability/admin/invitations" class="<%= currentPage === 'admin-invitations' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50' %> inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors" title="View Invitations">
              <svg class="mr-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
              </svg>
              Invites
            </a>
          <% } %>
          <!-- Partner roles (partner_admin, partner_viewer) do not see admin links -->

        </div>
      </div>

      <!-- Right side: User info & logout -->
      <div class="flex items-center gap-4">
        <a href="/observability/settings/change-password" class="text-muted-foreground hover:text-foreground transition-smooth" title="Change Password">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
          </svg>
        </a>
        <div class="flex items-center gap-2">
          <span class="text-foreground/70 text-sm font-medium">👤 <%= username %></span>
          <% if (accessScope && accessScope.scope_type) { %>
            <span class="inline-flex items-center text-xs font-medium text-gray-600" title="Access Scope: <%= accessScope.scope_type %>">
              <svg class="mr-1 h-3.5 w-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <% if (accessScope.scope_type === 'country') { %>
                <%= accessScope.scope_value.country_codes.length %> <%= accessScope.scope_value.country_codes.length === 1 ? 'Country' : 'Countries' %>
              <% } else if (accessScope.scope_type === 'school') { %>
                <%= accessScope.scope_value.school_names.length %> <%= accessScope.scope_value.school_names.length === 1 ? 'School' : 'Schools' %>
              <% } else if (accessScope.scope_type === 'phone_list') { %>
                <%= accessScope.scope_value.phone_numbers.length %> <%= accessScope.scope_value.phone_numbers.length === 1 ? 'User' : 'Users' %>
              <% } else if (accessScope.scope_type === 'combined') { %>
                Combined Scope
              <% } else if (accessScope.scope_type === 'all') { %>
                All Users
              <% } %>
            </span>
          <% } else if (userRole === 'super_admin') { %>
            <span class="inline-flex items-center text-xs font-medium text-gray-600" title="Super Admin - Full Access">
              <svg class="mr-1 h-3.5 w-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
              </svg>
              All Access
            </span>
          <% } %>
        </div>
        <a href="/observability/logout" class="btn-destructive">
          Logout
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Spacer to prevent content from going under fixed nav -->
<div class="h-16"></div>
