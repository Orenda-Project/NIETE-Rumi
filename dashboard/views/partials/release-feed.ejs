function getIcon(iconName) {
  return icons[iconName] || icons.sparkles;
}
%>

<% if (releaseNotes && releaseNotes.length > 0) { %>
<div class="release-feed">
  <div class="release-feed-header">
    <%- icons.sparkles %>
    <span>What's new with Rumi</span>
  </div>

  <div class="release-feed-list">
    <div class="release-feed-scroll">
      <% releaseNotes.forEach(function(note) { %>
        <div class="release-item">
          <div class="release-item-meta">
            <span class="release-item-icon category-icon <%= note.category %>">
              <%- getIcon(note.icon) %>
            </span>
            <span class="release-item-date"><%= timeAgo(note.created_at) %></span>
          </div>
          <div class="release-item-title"><%= note.title %></div>
        </div>
      <% }); %>
    </div>
  </div>

  <a href="/observability/release-notes" class="release-feed-link">
    <span>See all updates</span>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </a>
</div>
<% } %>
