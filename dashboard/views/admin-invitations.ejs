<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Rumi Observability Portal</title>
  <link rel="icon" type="image/png" href="/images/rumi-logo.png">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-background">
  <!-- Navigation -->
  <%- include("partials/navigation", { currentPage: "admin-invitations", username: username, userRole: userRole }) %>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
    <div class="px-4 py-6 sm:px-0">
      <!-- Header -->
      <div class="flex justify-between items-center mb-6">
        <div>
          <h2 class="text-2xl font-bold text-foreground">Invitation Management</h2>
          <p class="text-sm text-muted-foreground mt-1">Create and manage partner admin invitations</p>
        </div>
        <a href="/observability/admin/users" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
          <svg class="mr-2 -ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          User Management
        </a>
      </div>

      <!-- Summary Cards -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="card-primary border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-muted-foreground truncate">Pending</dt>
            <dd class="mt-1 text-3xl font-semibold text-foreground"><%= stats.pending %></dd>
            <p class="mt-2 text-xs text-muted-foreground">Awaiting acceptance</p>
          </div>
        </div>

        <div class="card-primary border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-muted-foreground truncate">Accepted</dt>
            <dd class="mt-1 text-3xl font-semibold text-foreground"><%= stats.accepted %></dd>
            <p class="mt-2 text-xs text-muted-foreground">Active users</p>
          </div>
        </div>

        <div class="card-primary border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-muted-foreground truncate">Expired</dt>
            <dd class="mt-1 text-3xl font-semibold text-foreground"><%= stats.expired %></dd>
            <p class="mt-2 text-xs text-muted-foreground">Past deadline</p>
          </div>
        </div>

        <div class="card-primary border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-muted-foreground truncate">Revoked</dt>
            <dd class="mt-1 text-3xl font-semibold text-foreground"><%= stats.revoked %></dd>
            <p class="mt-2 text-xs text-muted-foreground">Cancelled</p>
          </div>
        </div>
      </div>

      <!-- Create Invitation Form -->
      <div class="card-primary mb-8">
        <div class="px-6 py-4 border-b border-border">
          <h3 class="text-lg font-medium text-foreground">Create New Invitation</h3>
          <p class="text-sm text-muted-foreground mt-1">Send an invitation email to a new partner admin</p>
        </div>

        <div class="px-6 py-6">
          <form id="invitationForm" class="space-y-6">
            <!-- Email Input -->
            <div>
              <label for="email" class="block text-sm font-medium text-foreground">Email Address</label>
              <input type="email" id="email" required
                     class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
              <p class="mt-1 text-xs text-muted-foreground">Invitation email will be sent to this address</p>
            </div>

            <!-- Role Selection -->
            <div>
              <label for="role" class="block text-sm font-medium text-foreground">Role</label>
              <select id="role" required
                      class="mt-1 block w-full px-3 py-2 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                <option value="partner_admin">Partner Admin</option>
                <option value="partner_viewer">Partner Viewer (Read-only)</option>
              </select>
            </div>

            <!-- Scope Builder -->
            <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
              <h4 class="text-sm font-medium text-foreground mb-4">Access Scope Configuration</h4>

              <!-- Scope Type Selection -->
              <div class="mb-4">
                <label class="block text-sm font-medium text-foreground mb-2">Scope Type</label>
                <div class="grid grid-cols-2 md:grid-cols-5 gap-2">
                  <button type="button" class="scope-type-btn" data-scope-type="all">
                    <span class="font-medium">All Users</span>
                  </button>
                  <button type="button" class="scope-type-btn" data-scope-type="country">
                    <span class="font-medium">By Country</span>
                  </button>
                  <button type="button" class="scope-type-btn active" data-scope-type="school">
                    <span class="font-medium">By School</span>
                  </button>
                  <button type="button" class="scope-type-btn" data-scope-type="phone_list">
                    <span class="font-medium">Phone List</span>
                  </button>
                  <button type="button" class="scope-type-btn" data-scope-type="combined">
                    <span class="font-medium">Combined</span>
                  </button>
                </div>
              </div>

              <!-- Dynamic Scope Inputs -->
              <div id="scopeInputs" class="space-y-4">
                <!-- All Users Scope (no additional inputs needed) -->
                <div id="scope-all" class="scope-panel hidden">
                  <p class="text-sm text-muted-foreground">This user will have access to all users in the system.</p>
                </div>

                <!-- Country Scope -->
                <div id="scope-country" class="scope-panel hidden">
                  <label class="block text-sm font-medium text-foreground mb-2">Country Codes</label>
                  <div class="flex gap-2 mb-2">
                    <input type="text" id="countryCodeInput" placeholder="+92"
                           class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 text-sm">
                    <button type="button" id="addCountryCode" class="btn-secondary">Add</button>
                  </div>
                  <div id="countryCodeList" class="flex flex-wrap gap-2"></div>
                </div>

                <!-- School Scope -->
                <div id="scope-school" class="scope-panel">
                  <label class="block text-sm font-medium text-foreground mb-2">School Names</label>
                  <div class="mb-2">
                    <input type="text" id="schoolNameInput" placeholder="Type school name..."
                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 text-sm"
                           autocomplete="off">
                    <div id="schoolSuggestions" class="mt-1 max-h-48 overflow-y-auto bg-white border border-gray-300 rounded-md shadow-sm hidden"></div>
                  </div>
                  <div id="schoolNameList" class="flex flex-wrap gap-2"></div>
                </div>

                <!-- Phone List Scope -->
                <div id="scope-phone_list" class="scope-panel hidden">
                  <label class="block text-sm font-medium text-foreground mb-2">Phone Numbers</label>
                  <div class="flex gap-2 mb-2">
                    <input type="text" id="phoneNumberInput" placeholder="923001234567"
                           class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 text-sm">
                    <button type="button" id="addPhoneNumber" class="btn-secondary">Add</button>
                  </div>
                  <div id="phoneNumberList" class="flex flex-wrap gap-2"></div>
                  <p class="text-xs text-muted-foreground mt-2">Enter phone numbers in E.164 format (e.g., 923001234567)</p>
                </div>

                <!-- Combined Scope -->
                <div id="scope-combined" class="scope-panel hidden">
                  <div class="space-y-4">
                    <div>
                      <label class="block text-sm font-medium text-foreground mb-2">Country Codes (Optional)</label>
                      <div class="flex gap-2 mb-2">
                        <input type="text" id="combinedCountryInput" placeholder="+92"
                               class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 text-sm">
                        <button type="button" id="addCombinedCountry" class="btn-secondary">Add</button>
                      </div>
                      <div id="combinedCountryList" class="flex flex-wrap gap-2"></div>
                    </div>

                    <div>
                      <label class="block text-sm font-medium text-foreground mb-2">School Names (Optional)</label>
                      <div class="flex gap-2 mb-2">
                        <input type="text" id="combinedSchoolInput" placeholder="School name"
                               class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 text-sm">
                        <button type="button" id="addCombinedSchool" class="btn-secondary">Add</button>
                      </div>
                      <div id="combinedSchoolList" class="flex flex-wrap gap-2"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Preview Button -->
              <div class="mt-4">
                <button type="button" id="previewBtn" class="btn-secondary">
                  <svg class="inline h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                  Preview User Access
                </button>
              </div>

              <!-- Preview Panel -->
              <div id="previewPanel" class="mt-4 hidden">
                <div class="bg-white border border-gray-200 rounded-lg p-4">
                  <div class="flex justify-between items-center mb-2">
                    <div>
                      <h5 class="text-sm font-medium text-foreground">
                        Scope includes <span id="previewCount" class="text-primary font-bold">0</span> users
                      </h5>
                      <p class="text-xs text-muted-foreground mt-1">
                        <span id="registeredCount">0</span> registered, <span id="unregisteredCount">0</span> unregistered
                      </p>
                    </div>
                    <button type="button" id="closePreview" class="text-gray-400 hover:text-gray-600">
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </button>
                  </div>
                  <p id="previewNote" class="text-xs text-muted-foreground mb-2 hidden">
                    Showing first 100 users
                  </p>
                  <div id="previewContent" class="max-h-64 overflow-y-auto text-xs space-y-1">
                    <!-- Preview will be inserted here -->
                  </div>
                </div>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="flex justify-end">
              <button type="submit" id="submitBtn" class="btn-primary">
                <svg class="inline h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                Send Invitation
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Pending Invitations -->
      <div class="card-primary mb-8">
        <div class="px-6 py-4 border-b border-border">
          <h3 class="text-lg font-medium text-foreground">Pending Invitations (<%= pendingInvitations.length %>)</h3>
        </div>
        <div class="overflow-x-auto">
          <% if (pendingInvitations.length === 0) { %>
            <div class="px-6 py-8 text-center text-muted-foreground">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <p class="mt-2">No pending invitations</p>
            </div>
          <% } else { %>
            <table class="min-w-full divide-y divide-border">
              <thead class="bg-background">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Email</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Role</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Scope</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Expires</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-border">
                <% pendingInvitations.forEach(inv => {
                  const scopeConfig = typeof inv.scope_config === 'string' ? JSON.parse(inv.scope_config) : inv.scope_config;
                  const expiresAt = new Date(inv.expires_at);
                  const now = new Date();
                  const daysLeft = Math.ceil((expiresAt - now) / (1000 * 60 * 60 * 24));
                %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-foreground"><%= inv.email %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-50 text-indigo-700 border border-indigo-200">
                      <%= inv.role %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-xs text-foreground">
                    <span class="capitalize"><%= scopeConfig.scope_type %></span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-xs">
                    <span class="<%= daysLeft <= 1 ? 'text-red-600 font-medium' : 'text-muted-foreground' %>">
                      <%= daysLeft %> day<%= daysLeft !== 1 ? 's' : '' %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm space-x-2">
                    <button class="resend-btn text-indigo-600 hover:text-indigo-900" data-token="<%= inv.token %>">Resend</button>
                    <button class="revoke-btn text-red-600 hover:text-red-900" data-token="<%= inv.token %>">Revoke</button>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

      <!-- Invitation History -->
      <div class="card-primary">
        <div class="px-6 py-4 border-b border-border">
          <h3 class="text-lg font-medium text-foreground">Recent Invitations</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-border">
            <thead class="bg-background">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Email</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Created</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Accepted</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-border">
              <% allInvitations.slice(0, 20).forEach(inv => { %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-foreground"><%= inv.email %></td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (inv.status === 'accepted') { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-50 text-green-700 border border-green-200">Accepted</span>
                  <% } else if (inv.status === 'pending') { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200">Pending</span>
                  <% } else if (inv.status === 'revoked') { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200">Revoked</span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200"><%= inv.status %></span>
                  <% } %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-xs text-muted-foreground">
                  <%= new Date(inv.created_at).toLocaleDateString() %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-xs text-muted-foreground">
                  <%= inv.accepted_at ? new Date(inv.accepted_at).toLocaleDateString() : '-' %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <style>
    .scope-type-btn {
      @apply px-4 py-2 text-sm border border-gray-300 rounded-md bg-white hover:bg-gray-50 transition-colors;
    }
    .scope-type-btn.active {
      @apply bg-indigo-600 text-white border-indigo-600 hover:bg-indigo-700;
    }
    .scope-panel {
      @apply transition-all duration-200;
    }
    .chip {
      @apply inline-flex items-center px-3 py-1.5 rounded-md text-sm bg-gray-100 text-gray-700 border border-gray-200;
    }
    .chip button {
      @apply ml-2 text-gray-500 hover:text-gray-700;
    }
  </style>

  <script>
    // Scope state
    let currentScopeType = 'school';
    let countryCodes = [];
    let schoolNames = [];
    let phoneNumbers = [];
    let combinedCountries = [];
    let combinedSchools = [];

    // School autocomplete data
    let schoolData = [];

    // Scope type selection
    document.querySelectorAll('.scope-type-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.scope-type-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        currentScopeType = btn.dataset.scopeType;

        // Hide all panels
        document.querySelectorAll('.scope-panel').forEach(p => p.classList.add('hidden'));

        // Show selected panel
        document.getElementById(`scope-${currentScopeType}`).classList.remove('hidden');
      });
    });

    // Country code management
    document.getElementById('addCountryCode').addEventListener('click', () => {
      const input = document.getElementById('countryCodeInput');
      const code = input.value.trim();

      if (code && !countryCodes.includes(code)) {
        countryCodes.push(code);
        updateChipList('countryCodeList', countryCodes, removeCountryCode);
        input.value = '';
      }
    });

    document.getElementById('countryCodeInput').addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        document.getElementById('addCountryCode').click();
      }
    });

    function removeCountryCode(code) {
      countryCodes = countryCodes.filter(c => c !== code);
      updateChipList('countryCodeList', countryCodes, removeCountryCode);
    }

    // School autocomplete
    const schoolInput = document.getElementById('schoolNameInput');
    const schoolSuggestions = document.getElementById('schoolSuggestions');

    schoolInput.addEventListener('input', async (e) => {
      const query = e.target.value.trim();

      if (query.length < 2) {
        schoolSuggestions.classList.add('hidden');
        return;
      }

      // Fetch school names from database
      try {
        const response = await fetch(`/observability/api/users?search=${encodeURIComponent(query)}&fields=school_name&limit=20`);
        if (response.ok) {
          const data = await response.json();
          schoolData = [...new Set(data.users.map(u => u.school_name).filter(Boolean))];
          renderSchoolSuggestions(schoolData.filter(s => s.toLowerCase().includes(query.toLowerCase())));
        }
      } catch (error) {
        console.error('Error fetching school names:', error);
        // Fallback: use manual entry
      }
    });

    function renderSchoolSuggestions(suggestions) {
      if (suggestions.length === 0) {
        schoolSuggestions.classList.add('hidden');
        return;
      }

      schoolSuggestions.innerHTML = suggestions.map(s =>
        `<div class="px-3 py-2 hover:bg-gray-100 cursor-pointer text-sm" data-school="${s}">${s}</div>`
      ).join('');

      schoolSuggestions.querySelectorAll('[data-school]').forEach(el => {
        el.addEventListener('click', () => {
          const school = el.dataset.school;
          if (!schoolNames.includes(school)) {
            schoolNames.push(school);
            updateChipList('schoolNameList', schoolNames, removeSchoolName);
          }
          schoolInput.value = '';
          schoolSuggestions.classList.add('hidden');
        });
      });

      schoolSuggestions.classList.remove('hidden');
    }

    schoolInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const school = schoolInput.value.trim();
        if (school && !schoolNames.includes(school)) {
          schoolNames.push(school);
          updateChipList('schoolNameList', schoolNames, removeSchoolName);
          schoolInput.value = '';
          schoolSuggestions.classList.add('hidden');
        }
      }
    });

    function removeSchoolName(school) {
      schoolNames = schoolNames.filter(s => s !== school);
      updateChipList('schoolNameList', schoolNames, removeSchoolName);
    }

    // Phone number management
    document.getElementById('addPhoneNumber').addEventListener('click', () => {
      const input = document.getElementById('phoneNumberInput');
      const phone = input.value.trim();

      if (phone && !phoneNumbers.includes(phone)) {
        phoneNumbers.push(phone);
        updateChipList('phoneNumberList', phoneNumbers, removePhoneNumber);
        input.value = '';
      }
    });

    document.getElementById('phoneNumberInput').addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        document.getElementById('addPhoneNumber').click();
      }
    });

    function removePhoneNumber(phone) {
      phoneNumbers = phoneNumbers.filter(p => p !== phone);
      updateChipList('phoneNumberList', phoneNumbers, removePhoneNumber);
    }

    // Combined scope management
    document.getElementById('addCombinedCountry').addEventListener('click', () => {
      const input = document.getElementById('combinedCountryInput');
      const code = input.value.trim();

      if (code && !combinedCountries.includes(code)) {
        combinedCountries.push(code);
        updateChipList('combinedCountryList', combinedCountries, (c) => {
          combinedCountries = combinedCountries.filter(x => x !== c);
          updateChipList('combinedCountryList', combinedCountries, (c) => {
            combinedCountries = combinedCountries.filter(x => x !== c);
            updateChipList('combinedCountryList', combinedCountries, arguments.callee);
          });
        });
        input.value = '';
      }
    });

    document.getElementById('addCombinedSchool').addEventListener('click', () => {
      const input = document.getElementById('combinedSchoolInput');
      const school = input.value.trim();

      if (school && !combinedSchools.includes(school)) {
        combinedSchools.push(school);
        updateChipList('combinedSchoolList', combinedSchools, (s) => {
          combinedSchools = combinedSchools.filter(x => x !== s);
          updateChipList('combinedSchoolList', combinedSchools, arguments.callee);
        });
        input.value = '';
      }
    });

    // Utility: Update chip list
    function updateChipList(listId, items, removeCallback) {
      const list = document.getElementById(listId);
      list.innerHTML = items.map(item =>
        `<span class="chip">
          ${item}
          <button type="button" onclick="this.parentElement.remove(); (${removeCallback.toString()})('${item}')">×</button>
        </span>`
      ).join('');
    }

    // Preview functionality
    document.getElementById('previewBtn').addEventListener('click', async () => {
      const scopeValue = buildScopeValue();

      if (!scopeValue) {
        alert('Please configure scope values');
        return;
      }

      try {
        const response = await fetch('/observability/api/admin/scope-preview', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ scopeType: currentScopeType, scopeValue })
        });

        const result = await response.json();

        if (result.success) {
          document.getElementById('previewCount').textContent = result.count.toLocaleString();
          document.getElementById('registeredCount').textContent = (result.registeredCount || 0).toLocaleString();
          document.getElementById('unregisteredCount').textContent = (result.unregisteredCount || 0).toLocaleString();

          // Show note if there are more users than shown
          const previewNote = document.getElementById('previewNote');
          if (result.count > result.users.length) {
            previewNote.textContent = `Showing first ${result.users.length} of ${result.count.toLocaleString()} users`;
            previewNote.classList.remove('hidden');
          } else {
            previewNote.classList.add('hidden');
          }

          document.getElementById('previewContent').innerHTML = result.users.map(u =>
            `<div class="p-2 border-b border-gray-100 flex justify-between items-center">
              <div>
                <span class="font-medium">${u.phone_number}</span>
                ${u.first_name ? ` - ${u.first_name}` : ''}
                ${u.school_name ? ` <span class="text-gray-500">(${u.school_name})</span>` : ''}
              </div>
              <span class="text-xs px-2 py-0.5 rounded ${u.registration_completed ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}">
                ${u.registration_completed ? 'Registered' : 'Unregistered'}
              </span>
            </div>`
          ).join('') || '<p class="text-muted-foreground p-2">No users match this scope</p>';
          document.getElementById('previewPanel').classList.remove('hidden');
        } else {
          alert('Error: ' + result.error);
        }
      } catch (error) {
        console.error('Preview error:', error);
        alert('Failed to generate preview');
      }
    });

    document.getElementById('closePreview').addEventListener('click', () => {
      document.getElementById('previewPanel').classList.add('hidden');
    });

    // Build scope value object
    function buildScopeValue() {
      if (currentScopeType === 'all') {
        return {};
      } else if (currentScopeType === 'country') {
        return countryCodes.length > 0 ? { country_codes: countryCodes } : null;
      } else if (currentScopeType === 'school') {
        return schoolNames.length > 0 ? { school_names: schoolNames } : null;
      } else if (currentScopeType === 'phone_list') {
        return phoneNumbers.length > 0 ? { phone_numbers: phoneNumbers } : null;
      } else if (currentScopeType === 'combined') {
        const value = {};
        if (combinedCountries.length > 0) value.country_codes = combinedCountries;
        if (combinedSchools.length > 0) value.school_names = combinedSchools;
        return Object.keys(value).length > 0 ? value : null;
      }
      return null;
    }

    // Form submission
    document.getElementById('invitationForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = document.getElementById('email').value.trim();
      const role = document.getElementById('role').value;
      const scopeValue = buildScopeValue();

      if (!scopeValue) {
        alert('Please configure scope values');
        return;
      }

      const submitBtn = document.getElementById('submitBtn');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        const response = await fetch('/observability/api/admin/invitations/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            role,
            scopeConfig: { scope_type: currentScopeType, scope_value: scopeValue }
          })
        });

        const result = await response.json();

        if (result.success) {
          if (result.warning) {
            alert(result.warning);
          } else {
            alert('Invitation sent successfully!');
          }
          window.location.reload();
        } else {
          alert('Error: ' + result.error);
        }
      } catch (error) {
        console.error('Submit error:', error);
        alert('Failed to send invitation');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<svg class="inline h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>Send Invitation';
      }
    });

    // Resend/Revoke buttons
    document.querySelectorAll('.resend-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const token = btn.dataset.token;

        if (!confirm('Resend invitation email?')) return;

        try {
          const response = await fetch(`/observability/api/admin/invitations/${token}/resend`, {
            method: 'POST'
          });

          const result = await response.json();

          if (result.success) {
            alert('Invitation email resent successfully');
          } else {
            alert('Error: ' + result.error);
          }
        } catch (error) {
          console.error('Resend error:', error);
          alert('Failed to resend invitation');
        }
      });
    });

    document.querySelectorAll('.revoke-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const token = btn.dataset.token;

        if (!confirm('Revoke this invitation? This cannot be undone.')) return;

        try {
          const response = await fetch(`/observability/api/admin/invitations/${token}/revoke`, {
            method: 'POST'
          });

          const result = await response.json();

          if (result.success) {
            alert('Invitation revoked successfully');
            window.location.reload();
          } else {
            alert('Error: ' + result.error);
          }
        } catch (error) {
          console.error('Revoke error:', error);
          alert('Failed to revoke invitation');
        }
      });
    });
  </script>
</body>
</html>
