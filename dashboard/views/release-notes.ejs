function getIcon(iconName) {
  return icons[iconName] || icons.sparkles;
}

// Get current filter values
const currentEnv = typeof envFilter !== 'undefined' ? envFilter : 'all';
const currentCategory = typeof categoryFilter !== 'undefined' ? categoryFilter : 'all';
%>

  <!-- Main Content -->
  <main class="max-w-3xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-3xl font-light text-foreground mb-2">What's New with Rumi</h1>
      <p class="text-muted-foreground">Here's what I've been learning and improving lately...</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-2 mb-8 mt-6 justify-center">
      <a href="/observability/release-notes?env=all&category=<%= currentCategory %>"
         class="px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 <%= currentEnv === 'all' ? 'bg-primary text-white' : 'bg-secondary text-gray-700 hover:bg-gray-200' %>">
        All
      </a>
      <a href="/observability/release-notes?env=staging&category=<%= currentCategory %>"
         class="px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 <%= currentEnv === 'staging' ? 'bg-primary text-white' : 'bg-secondary text-gray-700 hover:bg-gray-200' %>">
        Staging
      </a>
      <a href="/observability/release-notes?env=production&category=<%= currentCategory %>"
         class="px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 <%= currentEnv === 'production' ? 'bg-primary text-white' : 'bg-secondary text-gray-700 hover:bg-gray-200' %>">
        Production
      </a>
      <span class="text-gray-400 flex items-center">|</span>
      <a href="/observability/release-notes?env=<%= currentEnv %>&category=all"
         class="px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 <%= currentCategory === 'all' ? 'bg-primary text-white' : 'bg-secondary text-gray-700 hover:bg-gray-200' %>">
        All Types
      </a>
      <a href="/observability/release-notes?env=<%= currentEnv %>&category=feature"
         class="px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 <%= currentCategory === 'feature' ? 'bg-primary text-white' : 'bg-secondary text-gray-700 hover:bg-gray-200' %>">
        Features
      </a>
      <a href="/observability/release-notes?env=<%= currentEnv %>&category=improvement"
         class="px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 <%= currentCategory === 'improvement' ? 'bg-primary text-white' : 'bg-secondary text-gray-700 hover:bg-gray-200' %>">
        Improvements
      </a>
      <a href="/observability/release-notes?env=<%= currentEnv %>&category=fix"
         class="px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 <%= currentCategory === 'fix' ? 'bg-primary text-white' : 'bg-secondary text-gray-700 hover:bg-gray-200' %>">
        Fixes
      </a>
    </div>

    <!-- Release Notes List -->
    <% if (releaseNotes && releaseNotes.length > 0) { %>
      <div class="space-y-6">
        <% releaseNotes.forEach(function(note) { %>
          <div class="card-primary p-6 <%= note.is_highlighted ? 'border-l-4 border-l-accent' : '' %>">
            <!-- Header Row -->
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-primary/10 text-primary">v<%= note.version %></span>
                <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= note.environment === 'production' ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %>">
                  <%= note.environment %>
                </span>
              </div>
              <span class="text-sm text-muted-foreground"><%= formatDate(note.created_at) %></span>
            </div>

            <!-- Title with Icon -->
            <h2 class="text-xl font-medium text-foreground mb-3 flex items-center gap-3">
              <span class="text-accent"><%- getIcon(note.icon) %></span>
              <%= note.title %>
            </h2>

            <!-- Description -->
            <p class="text-muted-foreground leading-relaxed mb-4"><%= note.description %></p>

            <!-- Details (expandable) -->
            <% if (note.details) { %>
              <details class="group">
                <summary class="text-sm font-medium text-primary cursor-pointer hover:text-accent transition-colors flex items-center gap-1">
                  <span class="group-open:hidden">+ More details</span>
                  <span class="hidden group-open:inline">- Less details</span>
                </summary>
                <div class="mt-3 p-4 rounded-lg bg-secondary/50 text-foreground text-sm leading-relaxed">
                  <%= note.details %>
                </div>
              </details>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="text-center py-16">
        <div class="text-muted-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
          </svg>
          <p class="text-lg mb-2">No updates match your filters</p>
          <p class="text-sm">Try adjusting the filters above</p>
        </div>
      </div>
    <% } %>
  </main>

</body>
</html>
