<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Rumi Observability Portal</title>
  <link rel="icon" type="image/png" href="/images/rumi-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    /* WhatsApp preview bubble */
    .whatsapp-preview {
      background: #dcf8c6;
      border-radius: 8px;
      padding: 12px 16px;
      max-width: 280px;
      position: relative;
      box-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }
    .whatsapp-preview::after {
      content: '';
      position: absolute;
      right: -8px;
      top: 12px;
      border-width: 8px;
      border-style: solid;
      border-color: transparent transparent transparent #dcf8c6;
    }
    .whatsapp-time {
      font-size: 11px;
      color: rgba(0,0,0,0.45);
      text-align: right;
      margin-top: 4px;
    }
    /* Progress animation */
    .progress-bar-animated {
      transition: width 0.3s ease;
    }
    /* Funnel cards */
    .funnel-card {
      transition: all 0.3s ease;
    }
    .funnel-card:hover {
      transform: translateY(-2px);
    }
  </style>
</head>
<body class="bg-gray-100 min-h-screen">
  <%- include("partials/navigation", { currentPage: "broadcast", username: username, userRole: userRole }) %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 flex items-center gap-3">
          <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
          </svg>
          Broadcast Message
        </h1>
        <p class="text-gray-600 mt-2">Send targeted messages to teachers and users</p>
      </div>
      <a href="/observability/broadcast/history"
         class="px-4 py-2 bg-white border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 flex items-center gap-2 shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        View History
      </a>
    </div>

    <!-- Warning Banner -->
    <div class="mb-6 p-4 rounded-lg bg-amber-50 border border-amber-200">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div>
          <p class="text-sm font-medium text-amber-800">Important: Broadcasts require Meta approval</p>
          <p class="text-sm text-amber-700 mt-1">
            Your message will be submitted as a WhatsApp template for approval. Text-only messages typically approve in 5-30 minutes.
            Test on staging first.
          </p>
        </div>
      </div>
    </div>

    <!-- Form Section (hidden when sending/complete) -->
    <div id="form-section">
      <form id="broadcast-form" class="space-y-6">
        <!-- Step 1: Compose Message -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2 mb-4">
            <span class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-sm font-bold">1</span>
            Compose Message
          </h2>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Message Input -->
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message Content</label>
              <textarea
                id="message"
                name="message"
                rows="6"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent placeholder-gray-400 resize-none"
                placeholder="Hey teachers! We have exciting news about Rumi..."
                maxlength="4096"
                required
              ></textarea>
              <p class="text-sm text-gray-500 mt-1">
                <span id="char-count">0</span>/4096 characters
              </p>
              <div id="content-warnings" class="mt-2 hidden">
                <p class="text-sm text-amber-600"></p>
              </div>
            </div>

            <!-- Preview -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">WhatsApp Preview</label>
              <div class="bg-gray-200 rounded-lg p-4" style="background-image: url('data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAoAAAAKCAYAAACNMs+9AAAAFklEQVR42mN8//HLfwYiAeOoQvoqBABbWAPlZLjqEwAAAABJRU5ErkJggg==');">
                <div class="whatsapp-preview">
                  <p id="preview-text" class="text-sm text-gray-800 whitespace-pre-wrap">Your message will appear here...</p>
                  <div class="whatsapp-time">
                    <span id="preview-time">10:30 AM</span>
                    <svg class="inline w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 16 15">
                      <path d="M15.01 3.316l-.478-.372a.365.365 0 0 0-.51.063L8.666 9.879a.32.32 0 0 1-.484.033l-.358-.325a.319.319 0 0 0-.484.032l-.378.483a.418.418 0 0 0 .036.541l1.32 1.266c.143.14.361.125.484-.033l6.272-8.048a.366.366 0 0 0-.064-.512zm-4.1 0l-.478-.372a.365.365 0 0 0-.51.063L4.566 9.879a.32.32 0 0 1-.484.033L1.891 7.769a.366.366 0 0 0-.515.006l-.423.433a.364.364 0 0 0 .006.514l3.258 3.185c.143.14.361.125.484-.033l6.272-8.048a.365.365 0 0 0-.063-.511z"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div id="approval-score" class="mt-3 hidden">
                <div class="flex items-center gap-2">
                  <span class="text-sm text-gray-600">Approval likelihood:</span>
                  <span id="approval-badge" class="px-2 py-1 text-xs font-semibold rounded-full"></span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2: Select Recipients -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2 mb-4">
            <span class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-sm font-bold">2</span>
            Select Recipients
          </h2>

          <!-- Recipient Mode Toggle -->
          <div class="mb-6 p-4 bg-gray-50 rounded-lg">
            <label class="block text-sm font-medium text-gray-700 mb-3">How would you like to select recipients?</label>
            <div class="flex flex-wrap gap-4">
              <label class="flex items-center cursor-pointer px-4 py-2 rounded-lg border-2 transition-all recipient-mode-option border-indigo-500 bg-indigo-50" data-mode="filter">
                <input type="radio" name="recipientMode" value="filter" checked
                       class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300"
                       onchange="toggleRecipientMode('filter')">
                <div class="ml-3">
                  <span class="text-sm font-medium text-gray-900">Filter by Activity/Country</span>
                  <p class="text-xs text-gray-500">Bulk messaging to user segments</p>
                </div>
              </label>
              <label class="flex items-center cursor-pointer px-4 py-2 rounded-lg border-2 transition-all recipient-mode-option border-gray-200 hover:border-indigo-300" data-mode="search">
                <input type="radio" name="recipientMode" value="search"
                       class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300"
                       onchange="toggleRecipientMode('search')">
                <div class="ml-3">
                  <span class="text-sm font-medium text-gray-900">Search & Select Users</span>
                  <p class="text-xs text-gray-500">Target specific individuals</p>
                </div>
              </label>
            </div>
          </div>

          <!-- Filter Mode (existing) -->
          <div id="filter-mode" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
              <div>
                <label for="activity" class="block text-sm font-medium text-gray-700 mb-2">User Activity</label>
                <select id="activity" name="activity" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                  <option value="all">All registered users</option>
                  <option value="24h">Active in last 24 hours</option>
                  <option value="7d">Active in last 7 days</option>
                  <option value="30d">Active in last 30 days</option>
                </select>
              </div>
              <div>
                <label for="country" class="block text-sm font-medium text-gray-700 mb-2">Country</label>
                <select id="country" name="country" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                  <option value="all">All countries</option>
                  <option value="92">Pakistan only</option>
                  <option value="94">Sri Lanka only</option>
                </select>
              </div>
            </div>

            <!-- Recipient Matrix -->
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="text-left py-2 px-3 font-medium text-gray-500"></th>
                    <th class="text-center py-2 px-3 font-medium text-gray-500">All Countries</th>
                    <th class="text-center py-2 px-3 font-medium text-gray-500">Pakistan</th>
                    <th class="text-center py-2 px-3 font-medium text-gray-500">Sri Lanka</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="border-b border-gray-100 hover:bg-gray-50 cursor-pointer" data-activity="all">
                    <td class="py-2 px-3 font-medium text-gray-700">All registered</td>
                    <td class="text-center py-2 px-3"><%= userCounts.all?.all || 0 %></td>
                    <td class="text-center py-2 px-3"><%= userCounts.all?.pakistan || 0 %></td>
                    <td class="text-center py-2 px-3"><%= userCounts.all?.sriLanka || 0 %></td>
                  </tr>
                  <tr class="border-b border-gray-100 hover:bg-gray-50 cursor-pointer" data-activity="24h">
                    <td class="py-2 px-3 font-medium text-gray-700">Active 24h</td>
                    <td class="text-center py-2 px-3"><%= userCounts['24h']?.all || 0 %></td>
                    <td class="text-center py-2 px-3"><%= userCounts['24h']?.pakistan || 0 %></td>
                    <td class="text-center py-2 px-3"><%= userCounts['24h']?.sriLanka || 0 %></td>
                  </tr>
                  <tr class="border-b border-gray-100 hover:bg-gray-50 cursor-pointer" data-activity="7d">
                    <td class="py-2 px-3 font-medium text-gray-700">Active 7d</td>
                    <td class="text-center py-2 px-3"><%= userCounts['7d']?.all || 0 %></td>
                    <td class="text-center py-2 px-3"><%= userCounts['7d']?.pakistan || 0 %></td>
                    <td class="text-center py-2 px-3"><%= userCounts['7d']?.sriLanka || 0 %></td>
                  </tr>
                  <tr class="hover:bg-gray-50 cursor-pointer" data-activity="30d">
                    <td class="py-2 px-3 font-medium text-gray-700">Active 30d</td>
                    <td class="text-center py-2 px-3"><%= userCounts['30d']?.all || 0 %></td>
                    <td class="text-center py-2 px-3"><%= userCounts['30d']?.pakistan || 0 %></td>
                    <td class="text-center py-2 px-3"><%= userCounts['30d']?.sriLanka || 0 %></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Search Mode (new) -->
          <div id="search-mode" class="space-y-4 hidden">
            <!-- Search Input -->
            <div class="relative">
              <label class="block text-sm font-medium text-gray-700 mb-1">Search Users</label>
              <div class="relative">
                <input type="text" id="user-search-input"
                       placeholder="Type name or phone number (min 3 chars)..."
                       class="w-full px-4 py-2 pl-10 border border-gray-300 rounded-lg
                              focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                       oninput="debounceSearch(this.value)"
                       autocomplete="off">
                <svg class="absolute left-3 top-2.5 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <div id="search-loading" class="absolute right-3 top-2.5 hidden">
                  <svg class="animate-spin h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                </div>
              </div>
            </div>

            <!-- Search Results Dropdown -->
            <div id="search-results" class="hidden border border-gray-200 rounded-lg bg-white shadow-lg max-h-60 overflow-y-auto">
              <!-- Populated by JavaScript -->
            </div>

            <!-- Selected Users Tags -->
            <div id="selected-users-section" class="hidden">
              <div class="flex items-center justify-between mb-2">
                <label class="block text-sm font-medium text-gray-700">
                  Selected Users (<span id="search-selected-count">0</span>)
                </label>
                <button type="button" onclick="clearAllSelectedUsers()"
                        class="text-sm text-red-600 hover:text-red-800">
                  Clear All
                </button>
              </div>
              <div id="selected-users-tags" class="flex flex-wrap gap-2">
                <!-- User tags populated by JavaScript -->
              </div>
            </div>
          </div>

          <!-- Hidden fields for form submission -->
          <input type="hidden" id="recipient-mode" name="recipientMode" value="filter">
          <input type="hidden" id="selected-user-ids" name="selectedUserIds" value="[]">

          <!-- Selection Summary -->
          <div class="mt-4 p-4 bg-indigo-50 rounded-lg">
            <div class="flex flex-wrap items-center justify-between gap-4">
              <div>
                <p class="text-sm font-medium text-indigo-900">
                  Selected: <span id="selected-count" class="text-lg font-bold"><%= userCounts.all?.all || 0 %></span> users
                </p>
                <p id="selected-details" class="text-xs text-indigo-700 mt-1">All registered, All countries</p>
              </div>
              <div class="text-right">
                <p class="text-sm text-indigo-700">
                  Est. time: <span id="est-time">~<%= Math.ceil((userCounts.all?.all || 0) * 50 / 1000) %> seconds</span>
                </p>
                <p class="text-sm text-indigo-700">
                  Est. cost: $<span id="est-cost-min">0.00</span> - $<span id="est-cost-max">0.00</span>
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3: Dry Run -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2 mb-4">
            <span class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-sm font-bold">3</span>
            Preview & Validate
          </h2>

          <div class="flex items-center gap-4">
            <button type="button" id="dry-run-btn" class="px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              Dry Run (Test)
            </button>
            <p class="text-sm text-gray-600">Preview recipients without sending</p>
          </div>

          <div id="dry-run-results" class="mt-4 hidden">
            <!-- Results populated by JS -->
          </div>
        </div>

        <!-- Step 4: Confirm & Send -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2 mb-4">
            <span class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-sm font-bold">4</span>
            Confirm & Submit
          </h2>

          <div class="max-w-md">
            <label for="adminPassword" class="block text-sm font-medium text-gray-700 mb-2">
              <svg class="inline w-4 h-4 mr-1 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
              Broadcast Password
            </label>
            <input
              type="password"
              id="adminPassword"
              name="adminPassword"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
              placeholder="Enter the special broadcast password..."
              required
            />
            <p class="text-sm text-amber-600 mt-1">
              <strong>Note:</strong> This is a special password for broadcast operations (not your login password).
            </p>
          </div>

          <div class="mt-6 flex items-center gap-4">
            <button type="submit" id="submit-btn" class="px-6 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
              Submit for Approval
            </button>
            <a href="/observability/broadcast/history" class="px-4 py-2 text-gray-600 hover:text-gray-800 font-medium">
              View History
            </a>
          </div>
        </div>
      </form>
    </div>

    <!-- Progress Section (hidden initially) -->
    <div id="progress-section" class="hidden">
      <div class="bg-white rounded-lg shadow p-8">
        <div class="text-center max-w-lg mx-auto">
          <!-- Status Icon -->
          <div id="status-icon" class="mb-6">
            <div class="w-16 h-16 mx-auto rounded-full bg-indigo-100 flex items-center justify-center">
              <svg class="w-8 h-8 text-indigo-600 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </div>
          </div>

          <h2 id="status-title" class="text-xl font-semibold text-gray-900 mb-2">Waiting for Meta Approval</h2>
          <p id="status-message" class="text-gray-600 mb-6">Your message template is being reviewed...</p>

          <!-- Progress Bar -->
          <div class="mb-6">
            <div class="w-full bg-gray-200 rounded-full h-3">
              <div id="progress-bar" class="bg-indigo-600 h-3 rounded-full progress-bar-animated" style="width: 0%"></div>
            </div>
            <div class="flex justify-between mt-2 text-sm">
              <span id="progress-percent" class="text-gray-600">0%</span>
              <span id="progress-stats" class="text-gray-600">Sent: 0 | Failed: 0</span>
            </div>
          </div>

          <!-- Cancel Button -->
          <button id="cancel-btn" class="px-4 py-2 text-red-600 hover:text-red-700 font-medium">
            Cancel Broadcast
          </button>
        </div>
      </div>
    </div>

    <!-- Results Section (hidden initially) -->
    <div id="results-section" class="hidden">
      <!-- Completion Header -->
      <div class="bg-white rounded-lg shadow p-6 mb-6">
        <div class="flex items-center gap-4">
          <div id="result-icon" class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <div>
            <h2 id="result-title" class="text-xl font-semibold text-gray-900">Broadcast Completed</h2>
            <p id="result-message" class="text-gray-600">Your message was sent successfully</p>
          </div>
        </div>
      </div>

      <!-- Delivery Funnel -->
      <div class="bg-white rounded-lg shadow p-6 mb-6">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            Delivery Analytics
          </h3>
          <span id="live-indicator" class="flex items-center gap-1 text-xs text-green-600">
            <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
            Live
          </span>
        </div>

        <div class="flex items-center justify-between px-4">
          <!-- Sent -->
          <div class="funnel-card text-center flex-1">
            <div class="w-20 h-20 mx-auto rounded-full bg-blue-100 flex items-center justify-center">
              <div>
                <p id="stat-sent" class="text-2xl font-bold text-blue-600">0</p>
                <p class="text-xs text-blue-600">Sent</p>
              </div>
            </div>
            <p class="mt-2 text-xs text-gray-500">100%</p>
          </div>

          <div class="text-gray-300 text-2xl">→</div>

          <!-- Delivered -->
          <div class="funnel-card text-center flex-1">
            <div class="w-20 h-20 mx-auto rounded-full bg-green-100 flex items-center justify-center">
              <div>
                <p id="stat-delivered" class="text-2xl font-bold text-green-600">0</p>
                <p class="text-xs text-green-600">Delivered</p>
              </div>
            </div>
            <p id="rate-delivered" class="mt-2 text-xs text-gray-500">0%</p>
          </div>

          <div class="text-gray-300 text-2xl">→</div>

          <!-- Read -->
          <div class="funnel-card text-center flex-1">
            <div class="w-20 h-20 mx-auto rounded-full bg-purple-100 flex items-center justify-center">
              <div>
                <p id="stat-read" class="text-2xl font-bold text-purple-600">0</p>
                <p class="text-xs text-purple-600">Read</p>
              </div>
            </div>
            <p id="rate-read" class="mt-2 text-xs text-gray-500">0%</p>
          </div>

          <div class="text-gray-300 text-2xl">→</div>

          <!-- Replied -->
          <div class="funnel-card text-center flex-1">
            <div class="w-20 h-20 mx-auto rounded-full bg-orange-100 flex items-center justify-center">
              <div>
                <p id="stat-replied" class="text-2xl font-bold text-orange-600">0</p>
                <p class="text-xs text-orange-600">Replied</p>
              </div>
            </div>
            <p id="rate-replied" class="mt-2 text-xs text-gray-500">0%</p>
          </div>
        </div>

        <p id="last-updated" class="text-xs text-gray-400 text-right mt-4">Updated just now</p>
      </div>

      <!-- Failed Messages -->
      <div id="errors-section" class="bg-white rounded-lg shadow p-6 mb-6 hidden">
        <h3 class="text-lg font-semibold text-red-600 flex items-center gap-2 mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Failed Messages (<span id="error-count">0</span>)
        </h3>
        <ul id="errors-list" class="space-y-1 text-sm">
          <!-- Populated by JS -->
        </ul>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-4">
        <a href="/observability/broadcast" class="px-6 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
          New Broadcast
        </a>
        <a href="/observability/broadcast/history" class="px-4 py-2 text-gray-600 hover:text-gray-800 font-medium">
          View History
        </a>
      </div>
    </div>
  </div>

  <script>
    // User counts from server
    const userCounts = <%- JSON.stringify(userCounts) %>;

    // DOM elements
    const form = document.getElementById('broadcast-form');
    const messageInput = document.getElementById('message');
    const charCount = document.getElementById('char-count');
    const previewText = document.getElementById('preview-text');
    const activitySelect = document.getElementById('activity');
    const countrySelect = document.getElementById('country');
    const selectedCount = document.getElementById('selected-count');
    const selectedDetails = document.getElementById('selected-details');
    const estTime = document.getElementById('est-time');
    const estCostMin = document.getElementById('est-cost-min');
    const estCostMax = document.getElementById('est-cost-max');
    const dryRunBtn = document.getElementById('dry-run-btn');
    const dryRunResults = document.getElementById('dry-run-results');
    const submitBtn = document.getElementById('submit-btn');
    const formSection = document.getElementById('form-section');
    const progressSection = document.getElementById('progress-section');
    const resultsSection = document.getElementById('results-section');
    const cancelBtn = document.getElementById('cancel-btn');

    let currentBroadcastId = null;
    let eventSource = null;

    // User search state
    let selectedUsers = [];
    let searchDebounceTimer = null;
    let currentRecipientMode = 'filter';

    // Toggle between filter and search modes
    function toggleRecipientMode(mode) {
      currentRecipientMode = mode;
      document.getElementById('filter-mode').classList.toggle('hidden', mode !== 'filter');
      document.getElementById('search-mode').classList.toggle('hidden', mode !== 'search');
      document.getElementById('recipient-mode').value = mode;

      // Update mode option styling
      document.querySelectorAll('.recipient-mode-option').forEach(el => {
        if (el.dataset.mode === mode) {
          el.classList.add('border-indigo-500', 'bg-indigo-50');
          el.classList.remove('border-gray-200');
        } else {
          el.classList.remove('border-indigo-500', 'bg-indigo-50');
          el.classList.add('border-gray-200');
        }
      });

      // Update selection summary
      if (mode === 'filter') {
        updateSelection();
      } else {
        updateSelectedUsersUI();
      }
    }

    // Debounced search
    function debounceSearch(query) {
      clearTimeout(searchDebounceTimer);

      if (query.length < 3) {
        document.getElementById('search-results').classList.add('hidden');
        return;
      }

      document.getElementById('search-loading').classList.remove('hidden');
      searchDebounceTimer = setTimeout(() => searchUsers(query), 300);
    }

    // Search users API call
    async function searchUsers(query) {
      try {
        const response = await fetch(`/observability/api/broadcast/search-users?q=${encodeURIComponent(query)}&limit=20`);
        const data = await response.json();

        if (!data.success) {
          throw new Error(data.error);
        }

        renderSearchResults(data.users);
      } catch (error) {
        console.error('Search error:', error);
        renderSearchResults([], error.message);
      } finally {
        document.getElementById('search-loading').classList.add('hidden');
      }
    }

    // Render search results dropdown
    function renderSearchResults(users, errorMessage = null) {
      const container = document.getElementById('search-results');

      if (errorMessage) {
        container.innerHTML = `<div class="p-4 text-sm text-red-600">${errorMessage}</div>`;
        container.classList.remove('hidden');
        return;
      }

      if (users.length === 0) {
        container.innerHTML = `<div class="p-4 text-sm text-gray-500">No users found</div>`;
        container.classList.remove('hidden');
        return;
      }

      // Filter out already selected users
      const selectedIds = new Set(selectedUsers.map(u => u.id));
      const availableUsers = users.filter(u => !selectedIds.has(u.id));

      if (availableUsers.length === 0) {
        container.innerHTML = `<div class="p-4 text-sm text-gray-500">All matching users already selected</div>`;
        container.classList.remove('hidden');
        return;
      }

      container.innerHTML = availableUsers.map(user => `
        <div class="flex items-center justify-between p-3 hover:bg-gray-50 cursor-pointer border-b border-gray-100 last:border-0"
             onclick='selectUser(${JSON.stringify(user).replace(/'/g, "&#39;")})'>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center">
              <span class="text-sm font-medium text-indigo-600">
                ${user.displayName.charAt(0).toUpperCase()}
              </span>
            </div>
            <div>
              <div class="text-sm font-medium text-gray-900">${user.displayName}</div>
              <div class="text-xs text-gray-500">${user.phoneMasked} · ${user.country}</div>
            </div>
          </div>
          <button type="button" class="p-1 text-indigo-600 hover:bg-indigo-50 rounded">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
          </button>
        </div>
      `).join('');

      container.classList.remove('hidden');
    }

    // Select a user
    function selectUser(user) {
      if (!selectedUsers.find(u => u.id === user.id)) {
        selectedUsers.push(user);
        updateSelectedUsersUI();

        // Clear search
        document.getElementById('user-search-input').value = '';
        document.getElementById('search-results').classList.add('hidden');
      }
    }

    // Remove a user
    function removeUser(userId) {
      selectedUsers = selectedUsers.filter(u => u.id !== userId);
      updateSelectedUsersUI();
    }

    // Clear all selected users
    function clearAllSelectedUsers() {
      selectedUsers = [];
      updateSelectedUsersUI();
    }

    // Update the selected users UI
    function updateSelectedUsersUI() {
      const section = document.getElementById('selected-users-section');
      const tagsContainer = document.getElementById('selected-users-tags');
      const countSpan = document.getElementById('search-selected-count');

      countSpan.textContent = selectedUsers.length;

      if (selectedUsers.length === 0) {
        section.classList.add('hidden');
        selectedCount.textContent = '0';
        selectedDetails.textContent = 'No users selected';
        estTime.textContent = '~0 seconds';
        estCostMin.textContent = '0.00';
        estCostMax.textContent = '0.00';
        return;
      }

      section.classList.remove('hidden');
      tagsContainer.innerHTML = selectedUsers.map(user => `
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 border border-indigo-200 rounded-lg">
          <div>
            <div class="text-sm font-medium text-indigo-900">${user.displayName}</div>
            <div class="text-xs text-indigo-600">${user.phoneMasked}</div>
          </div>
          <button type="button" onclick="removeUser('${user.id}')"
                  class="p-0.5 text-indigo-400 hover:text-indigo-600 hover:bg-indigo-100 rounded">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      `).join('');

      // Update hidden field
      document.getElementById('selected-user-ids').value = JSON.stringify(selectedUsers.map(u => u.id));

      // Update summary
      selectedCount.textContent = selectedUsers.length;
      selectedDetails.textContent = `${selectedUsers.length} specific user${selectedUsers.length > 1 ? 's' : ''} selected`;

      // Estimate time (50ms per message)
      const seconds = Math.ceil((selectedUsers.length * 50) / 1000);
      estTime.textContent = seconds < 60 ? `~${seconds} seconds` : `~${Math.ceil(seconds / 60)} minutes`;

      // Cost estimate (assume Pakistan rate for simplicity)
      const baseCost = selectedUsers.length * 0.0127;
      estCostMin.textContent = (baseCost * 0.8).toFixed(2);
      estCostMax.textContent = (baseCost * 1.2).toFixed(2);
    }

    // Close search results when clicking outside
    document.addEventListener('click', (e) => {
      const searchContainer = document.getElementById('search-mode');
      if (searchContainer && !searchContainer.contains(e.target)) {
        document.getElementById('search-results').classList.add('hidden');
      }
    });

    // Update character count and preview
    messageInput.addEventListener('input', () => {
      charCount.textContent = messageInput.value.length;
      previewText.textContent = messageInput.value || 'Your message will appear here...';
      updateApprovalScore();
    });

    // Update selection count when filters change
    function updateSelection() {
      const activity = activitySelect.value;
      const country = countrySelect.value;

      const counts = userCounts[activity] || { all: 0, pakistan: 0, sriLanka: 0 };
      const count = country === 'all' ? counts.all : (country === '92' ? counts.pakistan : counts.sriLanka);

      selectedCount.textContent = count;

      const activityLabels = { all: 'All registered', '24h': 'Active 24h', '7d': 'Active 7d', '30d': 'Active 30d' };
      const countryLabels = { all: 'All countries', '92': 'Pakistan', '94': 'Sri Lanka' };
      selectedDetails.textContent = `${activityLabels[activity]}, ${countryLabels[country]}`;

      // Update estimates
      const seconds = Math.ceil((count * 50) / 1000);
      if (seconds < 60) {
        estTime.textContent = `~${seconds} seconds`;
      } else {
        estTime.textContent = `~${Math.ceil(seconds / 60)} minutes`;
      }

      // Cost estimate (rough)
      const pkCount = country === 'all' ? counts.pakistan : (country === '92' ? counts.pakistan : 0);
      const lkCount = country === 'all' ? counts.sriLanka : (country === '94' ? counts.sriLanka : 0);
      const baseCost = (pkCount * 0.0127) + (lkCount * 0.0203);
      estCostMin.textContent = (baseCost * 0.8).toFixed(2);
      estCostMax.textContent = (baseCost * 1.2).toFixed(2);
    }

    activitySelect.addEventListener('change', updateSelection);
    countrySelect.addEventListener('change', updateSelection);
    updateSelection();

    // Update approval score
    function updateApprovalScore() {
      const message = messageInput.value;
      if (message.length < 10) {
        document.getElementById('approval-score').classList.add('hidden');
        return;
      }

      let score = 100;
      const capsRatio = (message.match(/[A-Z]/g) || []).length / message.length;
      if (capsRatio > 0.3) score -= 20;
      if (/https?:\/\/(?!hellorumi\.ai)/i.test(message)) score -= 30;
      if (/act now|limited time|hurry|urgent|last chance/i.test(message)) score -= 25;
      const emojiCount = (message.match(/[\u{1F300}-\u{1F9FF}]/gu) || []).length;
      if (emojiCount > 5) score -= 10;

      const badge = document.getElementById('approval-badge');
      const scoreDiv = document.getElementById('approval-score');

      scoreDiv.classList.remove('hidden');

      if (score >= 80) {
        badge.textContent = 'HIGH';
        badge.className = 'px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800';
      } else if (score >= 50) {
        badge.textContent = 'MEDIUM';
        badge.className = 'px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-800';
      } else {
        badge.textContent = 'LOW';
        badge.className = 'px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800';
      }
    }

    // Dry run
    dryRunBtn.addEventListener('click', async () => {
      const message = messageInput.value.trim();
      if (!message) {
        alert('Please enter a message first');
        return;
      }

      dryRunBtn.disabled = true;
      dryRunBtn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Running...';

      try {
        // Build request body based on recipient mode
        const dryRunBody = { message };

        if (currentRecipientMode === 'filter') {
          dryRunBody.activity = activitySelect.value;
          dryRunBody.country = countrySelect.value;
        } else {
          dryRunBody.recipientMode = 'search';
          dryRunBody.selectedUserIds = document.getElementById('selected-user-ids').value;
        }

        const response = await fetch('/observability/api/broadcast/dry-run', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(dryRunBody)
        });

        const data = await response.json();

        if (data.success) {
          dryRunResults.innerHTML = `
            <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
              <p class="font-medium text-green-800">Dry run successful!</p>
              <div class="mt-2 text-sm text-green-700 space-y-1">
                <p>Recipients: ${data.recipientCount} users</p>
                <p>Breakdown: ${data.breakdown.pakistan} Pakistan, ${data.breakdown.sriLanka} Sri Lanka</p>
                <p>Estimated time: ${data.estimatedTime}</p>
                <p>Estimated cost: $${data.estimatedCost.min} - $${data.estimatedCost.max}</p>
                ${data.contentAnalysis?.approvalLikelihood ? `<p>Approval likelihood: ${data.contentAnalysis.approvalLikelihood.likelihood}</p>` : ''}
              </div>
              ${data.sampleRecipients?.length ? `
                <p class="mt-3 font-medium text-green-800">Sample recipients:</p>
                <ul class="mt-1 text-sm text-green-700">
                  ${data.sampleRecipients.slice(0, 5).map(r => `<li>${r.name} (${r.phone}) - ${r.country}</li>`).join('')}
                </ul>
              ` : ''}
              ${data.warnings?.length ? `
                <div class="mt-3 p-2 bg-yellow-50 border border-yellow-200 rounded">
                  <p class="font-medium text-yellow-800">Warnings:</p>
                  <ul class="text-sm text-yellow-700">
                    ${data.warnings.map(w => `<li>- ${w}</li>`).join('')}
                  </ul>
                </div>
              ` : ''}
            </div>
          `;
        } else {
          dryRunResults.innerHTML = `
            <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
              <p class="font-medium text-red-800">Dry run failed</p>
              <p class="text-sm text-red-700 mt-1">${data.error}</p>
            </div>
          `;
        }

        dryRunResults.classList.remove('hidden');

      } catch (error) {
        dryRunResults.innerHTML = `
          <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="font-medium text-red-800">Error</p>
            <p class="text-sm text-red-700 mt-1">${error.message}</p>
          </div>
        `;
        dryRunResults.classList.remove('hidden');
      }

      dryRunBtn.disabled = false;
      dryRunBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg> Dry Run (Test)';
    });

    // Form submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!confirm('Are you sure you want to submit this broadcast for approval?')) {
        return;
      }

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Submitting...';

      try {
        // Build request body based on recipient mode
        const requestBody = {
          message: messageInput.value,
          recipientMode: currentRecipientMode,
          adminPassword: document.getElementById('adminPassword').value
        };

        if (currentRecipientMode === 'filter') {
          requestBody.activity = activitySelect.value;
          requestBody.country = countrySelect.value;
        } else {
          requestBody.selectedUserIds = document.getElementById('selected-user-ids').value;
        }

        const response = await fetch('/observability/api/broadcast/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(requestBody)
        });

        const data = await response.json();

        if (data.success) {
          currentBroadcastId = data.broadcastId;

          // Hide form, show progress
          formSection.classList.add('hidden');
          progressSection.classList.remove('hidden');

          // Start SSE polling
          startStatusPolling(data.broadcastId);

        } else {
          alert('Error: ' + data.error);
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg> Submit for Approval';
        }

      } catch (error) {
        alert('Error: ' + error.message);
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg> Submit for Approval';
      }
    });

    // SSE polling for status
    function startStatusPolling(broadcastId) {
      eventSource = new EventSource(`/observability/api/broadcast/${broadcastId}/status`);

      eventSource.addEventListener('status', (e) => {
        const data = JSON.parse(e.data);
        updateProgressUI(data);
      });

      eventSource.addEventListener('complete', (e) => {
        const data = JSON.parse(e.data);
        eventSource.close();
        showResults(data);
      });

      eventSource.addEventListener('error', (e) => {
        console.error('SSE error:', e);
        eventSource.close();
      });
    }

    function updateProgressUI(data) {
      const statusTitle = document.getElementById('status-title');
      const statusMessage = document.getElementById('status-message');
      const progressBar = document.getElementById('progress-bar');
      const progressPercent = document.getElementById('progress-percent');
      const progressStats = document.getElementById('progress-stats');
      const statusIcon = document.getElementById('status-icon');

      if (data.status === 'template_pending') {
        statusTitle.textContent = 'Waiting for Meta Approval';
        statusMessage.textContent = `Template status: ${data.templateStatus || 'PENDING'}`;
        progressBar.style.width = '10%';
        progressPercent.textContent = 'Pending';
      } else if (data.status === 'sending') {
        statusTitle.textContent = 'Sending Messages';
        statusMessage.textContent = `Sending to ${data.totalRecipients} users...`;
        progressBar.style.width = `${data.progress}%`;
        progressPercent.textContent = `${data.progress}%`;
        progressStats.textContent = `Sent: ${data.sentCount} | Failed: ${data.failedCount}`;

        // Change icon to sending
        statusIcon.innerHTML = `
          <div class="w-16 h-16 mx-auto rounded-full bg-blue-100 flex items-center justify-center">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </div>
        `;
      } else if (data.status === 'template_rejected') {
        statusTitle.textContent = 'Template Rejected';
        statusMessage.textContent = data.rejectedReason || 'Your message was rejected by Meta';
        progressBar.style.width = '0%';
        progressBar.classList.remove('bg-indigo-600');
        progressBar.classList.add('bg-red-600');

        statusIcon.innerHTML = `
          <div class="w-16 h-16 mx-auto rounded-full bg-red-100 flex items-center justify-center">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </div>
        `;
      }
    }

    function showResults(data) {
      progressSection.classList.add('hidden');
      resultsSection.classList.remove('hidden');

      const resultIcon = document.getElementById('result-icon');
      const resultTitle = document.getElementById('result-title');
      const resultMessage = document.getElementById('result-message');

      if (data.status === 'completed') {
        resultIcon.className = 'w-12 h-12 rounded-full bg-green-100 flex items-center justify-center';
        resultIcon.innerHTML = '<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
        resultTitle.textContent = 'Broadcast Completed';
        resultMessage.textContent = `Successfully sent to ${data.sent_count} users`;
      } else if (data.status === 'completed_with_errors') {
        resultIcon.className = 'w-12 h-12 rounded-full bg-yellow-100 flex items-center justify-center';
        resultIcon.innerHTML = '<svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>';
        resultTitle.textContent = 'Broadcast Completed with Errors';
        resultMessage.textContent = `Sent: ${data.sent_count} | Failed: ${data.failed_count}`;
      } else if (data.status === 'template_rejected') {
        resultIcon.className = 'w-12 h-12 rounded-full bg-red-100 flex items-center justify-center';
        resultIcon.innerHTML = '<svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
        resultTitle.textContent = 'Template Rejected';
        resultMessage.textContent = data.template_rejected_reason || 'Your message was rejected by Meta';
      } else if (data.status === 'cancelled') {
        resultIcon.className = 'w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center';
        resultIcon.innerHTML = '<svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
        resultTitle.textContent = 'Broadcast Cancelled';
        resultMessage.textContent = `Cancelled by ${data.cancelled_by || 'admin'}`;
      }

      // Update stats
      document.getElementById('stat-sent').textContent = data.sent_count || 0;
      document.getElementById('stat-delivered').textContent = data.delivered_count || 0;
      document.getElementById('stat-read').textContent = data.read_count || 0;
      document.getElementById('stat-replied').textContent = data.replied_count || 0;

      const total = data.sent_count || 1;
      document.getElementById('rate-delivered').textContent = `${((data.delivered_count || 0) / total * 100).toFixed(1)}%`;
      document.getElementById('rate-read').textContent = `${((data.read_count || 0) / total * 100).toFixed(1)}%`;
      document.getElementById('rate-replied').textContent = `${((data.replied_count || 0) / total * 100).toFixed(1)}%`;

      // Show errors if any
      if (data.errors && data.errors.length > 0) {
        document.getElementById('error-count').textContent = data.errors.length;
        document.getElementById('errors-list').innerHTML = data.errors.slice(0, 10).map(e =>
          `<li class="text-red-600">${e.phoneNumber}: ${e.error}</li>`
        ).join('');
        document.getElementById('errors-section').classList.remove('hidden');
      }

      // Start delivery polling
      if (currentBroadcastId && ['completed', 'completed_with_errors'].includes(data.status)) {
        startDeliveryPolling(currentBroadcastId);
      }
    }

    // Poll for delivery stats
    function startDeliveryPolling(broadcastId) {
      let pollCount = 0;
      const maxPolls = 120; // 10 minutes at 5 second intervals

      async function poll() {
        try {
          const response = await fetch(`/observability/api/broadcast/${broadcastId}/stats`);
          const data = await response.json();

          if (data.success) {
            document.getElementById('stat-delivered').textContent = data.counts.delivered;
            document.getElementById('stat-read').textContent = data.counts.read;
            document.getElementById('stat-replied').textContent = data.counts.replied;

            document.getElementById('rate-delivered').textContent = `${data.rates.deliveryRate}%`;
            document.getElementById('rate-read').textContent = `${data.rates.readRate}%`;
            document.getElementById('rate-replied').textContent = `${data.rates.replyRate}%`;

            document.getElementById('last-updated').textContent = `Updated ${new Date().toLocaleTimeString()}`;
          }

          pollCount++;
          if (pollCount < maxPolls) {
            setTimeout(poll, 5000);
          } else {
            document.getElementById('live-indicator').innerHTML = '<span class="text-gray-500">Polling stopped</span>';
          }
        } catch (error) {
          console.error('Stats polling error:', error);
        }
      }

      poll();
    }

    // Cancel broadcast
    cancelBtn.addEventListener('click', async () => {
      if (!currentBroadcastId) return;
      if (!confirm('Are you sure you want to cancel this broadcast?')) return;

      try {
        const response = await fetch(`/observability/api/broadcast/${currentBroadcastId}/cancel`, {
          method: 'POST'
        });

        const data = await response.json();

        if (data.success) {
          if (eventSource) eventSource.close();
          showResults({ status: 'cancelled', cancelled_by: '<%= username %>' });
        } else {
          alert('Error: ' + data.error);
        }
      } catch (error) {
        alert('Error: ' + error.message);
      }
    });

    // Update preview time
    function updatePreviewTime() {
      const now = new Date();
      document.getElementById('preview-time').textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }
    updatePreviewTime();
    setInterval(updatePreviewTime, 60000);
  </script>
</body>
</html>
