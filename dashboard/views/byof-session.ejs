<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Rumi Observability Portal</title>
  <link rel="icon" type="image/png" href="/images/rumi-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .chat-container {
      height: calc(100vh - 280px);
      min-height: 400px;
    }
    .message-bubble {
      max-width: 80%;
    }
    .message-bubble.user {
      margin-left: auto;
    }
    .message-bubble.assistant {
      margin-right: auto;
    }
  </style>
</head>
<body class="bg-gray-100 min-h-screen">
  <%- include("partials/navigation", { currentPage: "byof", username: user?.username || 'Guest', userRole: user?.role || 'viewer' }) %>

  <div class="max-w-4xl mx-auto px-4 py-6">
    <!-- Header -->
    <div class="mb-4 flex justify-between items-start">
      <div>
        <a href="/observability/byof" class="inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-2">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to The Forge
        </a>
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= session.type === 'bug' ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' %>">
            <%= session.type === 'bug' ? 'Bug' : 'Feature' %>
          </span>
          <h1 class="text-xl font-bold text-gray-900">
            <%= session.title || 'Untitled Session' %>
          </h1>
        </div>
      </div>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%=
        session.status === 'active' ? 'bg-blue-100 text-blue-800' :
        session.status === 'plan_ready' ? 'bg-yellow-100 text-yellow-800' :
        'bg-gray-100 text-gray-800'
      %>">
        <%= session.status.replace('_', ' ').toUpperCase() %>
      </span>
    </div>

    <!-- Plan Display (when status is plan_ready or approved) -->
    <div id="plan-container" class="<%= session.status === 'plan_ready' || session.status === 'approved' ? '' : 'hidden' %> mb-4 bg-white rounded-lg shadow p-4">
      <div class="flex justify-between items-start mb-3">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Implementation Plan</h2>
          <p id="plan-summary" class="text-sm text-gray-600 mt-1">Loading plan...</p>
        </div>
        <div id="plan-actions" class="flex gap-2 <%= byofRole === 'approver' && session.status === 'plan_ready' ? '' : 'hidden' %>">
          <button onclick="approvePlan()" class="px-3 py-1.5 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500">
            Approve
          </button>
          <button onclick="showRejectModal()" class="px-3 py-1.5 bg-red-600 text-white text-sm rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500">
            Reject
          </button>
        </div>
        <% if (session.status === 'approved') { %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
            ✓ Approved
          </span>
        <% } %>
      </div>
      <div class="border-t pt-3">
        <div id="plan-content" class="prose prose-sm max-w-none text-gray-700 whitespace-pre-wrap font-mono text-xs bg-gray-50 p-3 rounded overflow-auto max-h-96">
          Loading...
        </div>
        <div id="plan-meta" class="mt-3 flex flex-wrap gap-2 text-xs text-gray-500">
          <span id="plan-priority" class="inline-flex items-center px-2 py-0.5 rounded bg-gray-100"></span>
          <span id="plan-files" class="inline-flex items-center"></span>
        </div>
      </div>

      <!-- PR Linking Section (Phase 4) -->
      <div id="pr-section" class="hidden border-t mt-4 pt-4">
        <h3 class="text-sm font-medium text-gray-900 mb-2">Pull Request</h3>
        <div id="pr-display" class="hidden">
          <a id="pr-link" href="#" target="_blank" class="inline-flex items-center text-indigo-600 hover:text-indigo-800">
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M7.177 3.073L9.573.677A.25.25 0 0110 .854v4.792a.25.25 0 01-.427.177L7.177 3.427a.25.25 0 010-.354zM3.75 2.5a.75.75 0 100 1.5.75.75 0 000-1.5zm-2.25.75a2.25 2.25 0 113 2.122v5.256a2.251 2.251 0 11-1.5 0V5.372A2.25 2.25 0 011.5 3.25zM11 2.5h-1V4h1a1 1 0 011 1v5.628a2.251 2.251 0 101.5 0V5A2.5 2.5 0 0011 2.5zm1 10.25a.75.75 0 111.5 0 .75.75 0 01-1.5 0zM3.75 12a.75.75 0 100 1.5.75.75 0 000-1.5z"/>
            </svg>
            <span id="pr-url-text"></span>
          </a>
          <span id="pr-status" class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium"></span>
        </div>
        <div id="pr-form" class="<%= byofRole === 'approver' ? '' : 'hidden' %>">
          <div class="flex gap-2">
            <input type="text" id="pr-url-input" placeholder="https://github.com/owner/repo/pull/123"
              class="flex-1 px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
            <button onclick="linkPr()" class="px-4 py-2 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700">
              Link PR
            </button>
          </div>
          <p class="mt-1 text-xs text-gray-500">Link a GitHub PR to track implementation progress</p>
        </div>
      </div>
    </div>

    <!-- Reject Modal -->
    <div id="reject-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
      <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
        <h3 class="text-lg font-medium text-gray-900 mb-3">Reject Plan</h3>
        <p class="text-sm text-gray-600 mb-3">Please provide a reason for rejection. This will help the reporter improve the plan.</p>
        <textarea id="reject-reason" rows="3" placeholder="Reason for rejection..."
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"></textarea>
        <div class="flex gap-2 mt-4 justify-end">
          <button onclick="hideRejectModal()" class="px-4 py-2 text-gray-600 border rounded-lg hover:bg-gray-50">Cancel</button>
          <button onclick="rejectPlan()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">Reject</button>
        </div>
      </div>
    </div>

    <!-- Chat Container -->
    <div class="bg-white rounded-lg shadow flex flex-col">
      <!-- Messages -->
      <div id="messages-container" class="chat-container overflow-y-auto p-4 space-y-4">
        <% if (session.messages && session.messages.length > 0) { %>
          <% session.messages.forEach(msg => { %>
            <div class="message-bubble <%= msg.role %> <%= msg.role === 'user' ? 'bg-indigo-100 text-indigo-900' : 'bg-gray-100 text-gray-900' %> rounded-lg p-3">
              <div class="text-xs text-gray-500 mb-1">
                <%= msg.role === 'user' ? 'You' : 'AI Assistant' %> &middot; <%= new Date(msg.created_at).toLocaleTimeString() %>
              </div>
              <div class="whitespace-pre-wrap"><%= msg.content %></div>
              <% if (msg.attachments && msg.attachments.length > 0) { %>
                <div class="mt-2 flex flex-wrap gap-2">
                  <% msg.attachments.forEach(att => { %>
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-white border">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                      </svg>
                      Attachment
                    </span>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <!-- Welcome message -->
          <div class="message-bubble assistant bg-gray-100 text-gray-900 rounded-lg p-3">
            <div class="text-xs text-gray-500 mb-1">AI Assistant</div>
            <div class="whitespace-pre-wrap">Hello! I'm here to help you with your <%= session.type === 'bug' ? 'bug report' : 'feature request' %>.

<%= session.type === 'bug' ? `Please describe the bug you're experiencing. Include:
- What you expected to happen
- What actually happened
- Steps to reproduce (if known)
- Any error messages you saw

You can also attach screenshots if that helps!` : `Please describe the feature you'd like to see. Include:
- What problem it would solve
- How you envision it working
- Why it would be valuable

Feel free to share any mockups or examples!` %></div>
          </div>
        <% } %>
      </div>

      <!-- Input Area -->
      <div class="border-t p-4">
        <form id="message-form" class="flex gap-3">
          <div class="flex-1">
            <textarea id="message-input" rows="2" placeholder="Type your message..."
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 resize-none"
              onkeydown="if(event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); document.getElementById('message-form').requestSubmit(); }"></textarea>
          </div>
          <div class="flex flex-col gap-2">
            <button type="submit" id="send-btn" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed">
              <svg id="send-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
              <svg id="send-spinner" class="hidden w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
            </button>
          </div>
        </form>
        <p class="text-xs text-gray-500 mt-2">Press Enter to send, Shift+Enter for new line. Powered by Claude AI.</p>
      </div>
    </div>
  </div>

  <script>
    const sessionId = '<%= session.id %>';
    const sessionStatus = '<%= session.status %>';
    const byofRole = '<%= byofRole %>';
    const messagesContainer = document.getElementById('messages-container');

    // Scroll to bottom on load
    messagesContainer.scrollTop = messagesContainer.scrollHeight;

    // Load plan if status is plan_ready or approved
    if (sessionStatus === 'plan_ready' || sessionStatus === 'approved') {
      loadPlan();
    }

    let currentPlanId = null;

    async function loadPlan() {
      try {
        const response = await fetch(`/observability/byof/api/sessions/${sessionId}/plan`);
        const data = await response.json();

        if (data.success && data.plan) {
          currentPlanId = data.plan.id;
          document.getElementById('plan-summary').textContent = data.plan.summary || 'No summary available';
          document.getElementById('plan-content').textContent = data.plan.plan_markdown || 'No content available';

          // Priority badge
          const priorityEl = document.getElementById('plan-priority');
          const priorityColors = {
            low: 'bg-gray-100 text-gray-700',
            medium: 'bg-blue-100 text-blue-700',
            high: 'bg-orange-100 text-orange-700',
            critical: 'bg-red-100 text-red-700'
          };
          priorityEl.className = `inline-flex items-center px-2 py-0.5 rounded ${priorityColors[data.plan.priority] || priorityColors.medium}`;
          priorityEl.textContent = `Priority: ${data.plan.priority || 'medium'}`;

          // Affected files
          if (data.plan.affected_files && data.plan.affected_files.length > 0) {
            document.getElementById('plan-files').textContent = `Files: ${data.plan.affected_files.join(', ')}`;
          }

          // Show PR section for approved plans
          if (data.plan.status === 'approved' || data.plan.status === 'in_progress' ||
              data.plan.status === 'staging_live' || data.plan.status === 'production_live') {
            document.getElementById('pr-section').classList.remove('hidden');

            // If PR is linked, show it
            if (data.plan.pr_url) {
              document.getElementById('pr-display').classList.remove('hidden');
              document.getElementById('pr-form').classList.add('hidden');
              document.getElementById('pr-link').href = data.plan.pr_url;
              document.getElementById('pr-url-text').textContent = data.plan.pr_url.replace('https://github.com/', '');

              // Show PR status badge
              const statusEl = document.getElementById('pr-status');
              const statusColors = {
                in_progress: { bg: 'bg-blue-100', text: 'text-blue-800', label: 'In Progress' },
                staging_live: { bg: 'bg-yellow-100', text: 'text-yellow-800', label: 'Staging' },
                production_live: { bg: 'bg-green-100', text: 'text-green-800', label: 'Production' }
              };
              const status = statusColors[data.plan.status] || statusColors.in_progress;
              statusEl.className = `ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${status.bg} ${status.text}`;
              statusEl.textContent = status.label;
            }
          }
        }
      } catch (error) {
        console.error('Error loading plan:', error);
        document.getElementById('plan-summary').textContent = 'Failed to load plan';
      }
    }

    async function linkPr() {
      const prUrl = document.getElementById('pr-url-input').value.trim();
      if (!prUrl) {
        alert('Please enter a PR URL');
        return;
      }

      if (!currentPlanId) {
        alert('No plan found to link');
        return;
      }

      try {
        const response = await fetch(`/observability/byof/api/plans/${currentPlanId}/link-pr`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prUrl })
        });

        const data = await response.json();
        if (data.success) {
          alert('PR linked successfully!');
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Failed to link PR'));
        }
      } catch (error) {
        console.error('Error linking PR:', error);
        alert('Failed to link PR. Please try again.');
      }
    }

    function showRejectModal() {
      document.getElementById('reject-modal').classList.remove('hidden');
    }

    function hideRejectModal() {
      document.getElementById('reject-modal').classList.add('hidden');
      document.getElementById('reject-reason').value = '';
    }

    async function approvePlan() {
      if (!confirm('Are you sure you want to approve this plan?')) return;

      try {
        const response = await fetch(`/observability/byof/api/sessions/${sessionId}/plan/approve`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ notes: '' })
        });

        const data = await response.json();
        if (data.success) {
          alert('Plan approved successfully!');
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Failed to approve plan'));
        }
      } catch (error) {
        console.error('Error approving plan:', error);
        alert('Failed to approve plan. Please try again.');
      }
    }

    async function rejectPlan() {
      const reason = document.getElementById('reject-reason').value.trim();
      if (!reason) {
        alert('Please provide a reason for rejection');
        return;
      }

      try {
        const response = await fetch(`/observability/byof/api/sessions/${sessionId}/plan/reject`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reason })
        });

        const data = await response.json();
        if (data.success) {
          alert('Plan rejected. The reporter can continue the conversation to revise.');
          location.reload();
        } else {
          alert('Error: ' + (data.error || 'Failed to reject plan'));
        }
      } catch (error) {
        console.error('Error rejecting plan:', error);
        alert('Failed to reject plan. Please try again.');
      }

      hideRejectModal();
    }

    // Handle form submit
    document.getElementById('message-form').addEventListener('submit', async (e) => {
      e.preventDefault();

      const input = document.getElementById('message-input');
      const sendBtn = document.getElementById('send-btn');
      const sendIcon = document.getElementById('send-icon');
      const sendSpinner = document.getElementById('send-spinner');

      const content = input.value.trim();
      if (!content) return;

      // Disable button and show spinner
      sendBtn.disabled = true;
      sendIcon.classList.add('hidden');
      sendSpinner.classList.remove('hidden');

      // Add user message to UI immediately
      addMessageToUI('user', content);
      input.value = '';

      try {
        const response = await fetch(`/observability/byof/api/sessions/${sessionId}/messages`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ content })
        });

        const data = await response.json();

        if (!data.success) {
          alert('Error: ' + (data.error || 'Failed to send message'));
        }

        // Handle AI response
        if (data.aiResponse) {
          if (data.aiResponse.error) {
            addMessageToUI('assistant', `I apologize, but I encountered an issue: ${data.aiResponse.error}\n\nPlease try again.`);
          } else if (data.aiResponse.content) {
            addMessageToUI('assistant', data.aiResponse.content);
          }
        }

      } catch (error) {
        console.error('Error:', error);
        alert('Failed to send message. Please try again.');
      } finally {
        // Reset button
        sendBtn.disabled = false;
        sendIcon.classList.remove('hidden');
        sendSpinner.classList.add('hidden');
      }
    });

    function addMessageToUI(role, content) {
      const div = document.createElement('div');
      div.className = `message-bubble ${role} ${role === 'user' ? 'bg-indigo-100 text-indigo-900' : 'bg-gray-100 text-gray-900'} rounded-lg p-3`;
      div.innerHTML = `
        <div class="text-xs text-gray-500 mb-1">
          ${role === 'user' ? 'You' : 'AI Assistant'} &middot; ${new Date().toLocaleTimeString()}
        </div>
        <div class="whitespace-pre-wrap">${escapeHtml(content)}</div>
      `;
      messagesContainer.appendChild(div);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  </script>
</body>
</html>
