<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Rumi Observability Portal</title>
  <link rel="icon" type="image/png" href="/images/rumi-logo.png">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-gray-100 min-h-screen">
  <%- include("partials/navigation", { currentPage: "byof", username: user?.username || 'Guest', userRole: user?.role || 'viewer' }) %>

  <div class="max-w-2xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-6">
      <a href="/observability/byof" class="inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to The Forge
      </a>
      <h1 class="text-3xl font-bold text-gray-900 flex items-center gap-3">
        <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>
        </svg>
        New Forge Request
      </h1>
      <p class="text-gray-600 mt-2">Start crafting a bug fix or new feature</p>
    </div>

    <!-- Form -->
    <div class="bg-white rounded-lg shadow p-6">
      <form id="new-session-form">
        <!-- Type Selection -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-3">What would you like to report?</label>
          <div class="grid grid-cols-2 gap-4">
            <label class="relative">
              <input type="radio" name="type" value="bug" class="sr-only peer" checked>
              <div class="border-2 rounded-lg p-4 cursor-pointer transition-all peer-checked:border-red-500 peer-checked:bg-red-50 hover:border-gray-300">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900">Bug Report</p>
                    <p class="text-xs text-gray-500">Something isn't working</p>
                  </div>
                </div>
              </div>
            </label>
            <label class="relative">
              <input type="radio" name="type" value="feature" class="sr-only peer">
              <div class="border-2 rounded-lg p-4 cursor-pointer transition-all peer-checked:border-green-500 peer-checked:bg-green-50 hover:border-gray-300">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900">Feature Request</p>
                    <p class="text-xs text-gray-500">Suggest an improvement</p>
                  </div>
                </div>
              </div>
            </label>
          </div>
        </div>

        <!-- Title -->
        <div class="mb-6">
          <label for="title" class="block text-sm font-medium text-gray-700 mb-2">Title (optional)</label>
          <input type="text" id="title" name="title" placeholder="Brief description of your report..."
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
          <p class="mt-1 text-xs text-gray-500">You can add a title now or the AI will suggest one later.</p>
        </div>

        <!-- Submit -->
        <div class="flex justify-end gap-3">
          <a href="/observability/byof" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            Cancel
          </a>
          <button type="submit" id="submit-btn" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            <span id="submit-text">Start Conversation</span>
            <svg id="submit-spinner" class="hidden ml-2 w-4 h-4 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.getElementById('new-session-form').addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = document.getElementById('submit-btn');
      const submitText = document.getElementById('submit-text');
      const submitSpinner = document.getElementById('submit-spinner');

      // Disable button and show spinner
      submitBtn.disabled = true;
      submitText.textContent = 'Creating...';
      submitSpinner.classList.remove('hidden');

      try {
        const formData = new FormData(e.target);
        const type = formData.get('type');
        const title = formData.get('title') || null;

        const response = await fetch('/observability/byof/api/sessions', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ type, title })
        });

        const data = await response.json();

        if (data.success) {
          // Redirect to the new session
          window.location.href = `/observability/byof/session/${data.session.id}`;
        } else {
          alert('Error: ' + (data.error || 'Failed to create session'));
          // Reset button
          submitBtn.disabled = false;
          submitText.textContent = 'Start Conversation';
          submitSpinner.classList.add('hidden');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Failed to create session. Please try again.');
        // Reset button
        submitBtn.disabled = false;
        submitText.textContent = 'Start Conversation';
        submitSpinner.classList.add('hidden');
      }
    });
  </script>
</body>
</html>
