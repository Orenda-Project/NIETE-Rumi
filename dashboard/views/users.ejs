<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Rumi Observability Portal</title>
  <link rel="icon" type="image/png" href="/images/rumi-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      margin: 0;
      padding: 0;
      height: 100vh;
      overflow: hidden;
    }

    /* WhatsApp-style layout */
    .chat-container {
      display: flex;
      height: calc(100vh - 64px);
      background: #f0f2f5;
    }

    /* Left sidebar - Chat list */
    .chat-list {
      width: 400px;
      background: white;
      border-right: 1px solid #e5e7eb;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .chat-list-header {
      padding: 16px;
      background: white;
      border-bottom: 1px solid #e5e7eb;
    }

    .search-box {
      width: 100%;
      padding: 10px 16px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      font-size: 14px;
    }

    .chat-list-items {
      overflow-y: auto;
      flex: 1;
    }

    .chat-item {
      display: flex;
      align-items: center;
      padding: 12px 16px;
      cursor: pointer;
      border-bottom: 1px solid #f3f4f6;
      transition: background 0.2s;
    }

    .chat-item:hover {
      background: #f9fafb;
    }

    .chat-item.active {
      background: #e0e7ff;
    }

    .chat-item-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 600;
      font-size: 18px;
      margin-right: 12px;
      flex-shrink: 0;
    }

    .chat-item-content {
      flex: 1;
      min-width: 0;
    }

    .chat-item-name {
      font-weight: 600;
      font-size: 15px;
      color: #111827;
      margin-bottom: 4px;
    }

    .chat-item-last-message {
      font-size: 13px;
      color: #6b7280;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .chat-item-time {
      font-size: 12px;
      color: #9ca3af;
      margin-left: 8px;
    }

    /* Right pane - Chat messages */
    .chat-messages {
      flex: 1;
      display: flex;
      flex-direction: column;
      background: #efeae2;
      position: relative;
    }

    .chat-messages-header {
      background: #f0f2f5;
      padding: 16px 20px;
      border-bottom: 1px solid #d1d7db;
      display: flex;
      align-items: center;
    }

    .chat-messages-header-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      display: flex;
      align-items: center;
      justify-center;
      color: white;
      font-weight: 600;
      margin-right: 12px;
    }

    .chat-messages-header-info h3 {
      font-weight: 600;
      font-size: 16px;
      color: #111827;
      margin: 0;
    }

    .chat-messages-header-info p {
      font-size: 13px;
      color: #6b7280;
      margin: 2px 0 0 0;
    }

    .chat-messages-content {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
    }

    .chat-messages-empty {
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #6b7280;
    }

    .chat-messages-empty svg {
      width: 120px;
      height: 120px;
      margin-bottom: 20px;
      opacity: 0.3;
    }

    /* Message bubbles */
    .message-group {
      margin-bottom: 20px;
    }

    .message-date {
      text-align: center;
      margin: 20px 0;
    }

    .message-date span {
      background: #e1f0ff;
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 12px;
      color: #4b5563;
      font-weight: 500;
    }

    .message {
      display: flex;
      margin-bottom: 4px;
    }

    .message.user {
      justify-content: flex-start;
    }

    .message.assistant {
      justify-content: flex-end;
    }

    .message-bubble {
      max-width: 65%;
      padding: 8px 12px;
      border-radius: 8px;
      font-size: 14px;
      line-height: 1.5;
      position: relative;
    }

    .message.user .message-bubble {
      background: white;
      border-bottom-left-radius: 2px;
      box-shadow: 0 1px 0.5px rgba(0,0,0,0.13);
    }

    .message.assistant .message-bubble {
      background: #d9fdd3;
      border-bottom-right-radius: 2px;
      box-shadow: 0 1px 0.5px rgba(0,0,0,0.13);
    }

    .message-time {
      font-size: 11px;
      color: #667781;
      margin-top: 4px;
      text-align: right;
    }

    .message.user .message-time {
      text-align: left;
    }

    /* Lesson Plan & Coaching Session Cards */
    .inline-card {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 16px;
      margin: 12px 0;
      max-width: 400px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .inline-card-header {
      display: flex;
      align-items: center;
      margin-bottom: 12px;
    }

    .inline-card-icon {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: 12px;
    }

    .inline-card-icon.lesson-plan {
      background: #dbeafe;
      color: #1e40af;
    }

    .inline-card-icon.coaching-session {
      background: #fef3c7;
      color: #b45309;
    }

    .inline-card-title {
      font-weight: 600;
      font-size: 14px;
      color: #111827;
    }

    .inline-card-subtitle {
      font-size: 12px;
      color: #6b7280;
    }

    .inline-card-content {
      font-size: 13px;
      color: #374151;
      margin-bottom: 12px;
    }

    .inline-card-actions {
      display: flex;
      gap: 8px;
    }

    .inline-card-btn {
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      display: inline-block;
    }

    .inline-card-btn-primary {
      background: #4f46e5;
      color: white;
    }

    .inline-card-btn-primary:hover {
      background: #4338ca;
    }

    .inline-card-btn-secondary {
      background: #f3f4f6;
      color: #374151;
    }

    .inline-card-btn-secondary:hover {
      background: #e5e7eb;
    }

    /* PDF Preview */
    .pdf-preview {
      width: 100%;
      height: 400px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      margin: 12px 0;
    }

    /* Audio Player */
    .audio-player {
      width: 100%;
      margin: 12px 0;
    }

    .audio-player audio {
      width: 100%;
      height: 40px;
    }

    /* Session Messages */
    .session-messages {
      margin: 12px 0;
      padding: 12px;
      background: #f9fafb;
      border-radius: 8px;
      max-height: 300px;
      overflow-y: auto;
    }

    .session-message {
      margin-bottom: 8px;
      padding: 8px;
      border-radius: 6px;
      font-size: 13px;
    }

    .session-message.user-message {
      background: white;
      border-left: 3px solid #3b82f6;
    }

    .session-message.assistant-message {
      background: #dbeafe;
      border-left: 3px solid #1e40af;
    }

    .session-message-role {
      font-weight: 600;
      font-size: 11px;
      text-transform: uppercase;
      color: #6b7280;
      margin-bottom: 4px;
    }

    /* Audio message */
    .audio-message {
      background: white;
      border-radius: 20px;
      padding: 8px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      max-width: 300px;
    }

    .audio-play-btn {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: #4f46e5;
      color: white;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .audio-waveform {
      flex: 1;
      height: 24px;
      background: linear-gradient(90deg, #4f46e5 0%, #818cf8 100%);
      border-radius: 4px;
    }

    /* Loading spinner */
    .loading-spinner {
      display: inline-block;
      width: 24px;
      height: 24px;
      border: 3px solid #f3f4f6;
      border-top-color: #4f46e5;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
  <%- include("partials/navigation", { currentPage: "users", username: username, userRole: userRole }) %>


  <!-- WhatsApp-style Chat Container -->
  <div class="chat-container">
    <!-- Left Sidebar - Chat List -->
    <div class="chat-list">
      <div class="chat-list-header">
        <input
          type="text"
          id="searchChats"
          class="search-box"
          placeholder="Search chats..."
        />
      </div>
      <div class="chat-list-items" id="chatListItems">
        <% if (users && users.length > 0) { %>
          <% users.forEach(user => { %>
            <div class="chat-item" data-user-id="<%= user.id %>">
              <div class="chat-item-avatar">
                <%= (user.first_name || user.name || user.phone_number || 'U').charAt(0).toUpperCase() %>
              </div>
              <div class="chat-item-content">
                <div class="chat-item-name">
                  <%= user.first_name ? (user.first_name + ' ' + (user.last_name || '')) : (user.name || user.phone_number || 'Unknown User') %>
                  <% if (user.registration_state) { %>
                    <span style="font-size: 11px; padding: 2px 6px; border-radius: 4px; margin-left: 8px; background: <%= user.registration_state === 'completed' ? '#10b981' : user.registration_state === 'flow_sent' ? '#f59e0b' : user.registration_state === 'invited' ? '#3b82f6' : '#6b7280' %>; color: white; font-weight: 500;">
                      <%= user.registration_state === 'completed' ? '✓ Registered' : user.registration_state === 'flow_sent' ? '📋 Form Sent' : user.registration_state === 'invited' ? '📨 Invited' : user.registration_state %>
                    </span>
                  <% } %>
                </div>
                <div class="chat-item-last-message">
                  <%= user.phone_number || 'No phone number' %>
                  <% if (user.registration_started_at && !user.registration_completed) { %>
                    • Reg started <%= new Date(user.registration_started_at).toLocaleDateString() %>
                  <% } else if (user.registration_completed_at) { %>
                    • Reg completed <%= new Date(user.registration_completed_at).toLocaleDateString() %>
                  <% } %>
                </div>
              </div>
              <div class="chat-item-time">
                <%= user.created_at ? new Date(user.created_at).toLocaleDateString() : '' %>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div style="padding: 40px; text-align: center; color: #9ca3af;">
            No users found
          </div>
        <% } %>
      </div>

      <!-- Loading indicator for infinite scroll -->
      <div id="userListLoading" style="display: none; padding: 16px; text-align: center; color: #6b7280;">
        <div class="loading-spinner" style="margin: 0 auto;"></div>
        <p style="font-size: 13px; margin-top: 8px;">Loading more users...</p>
      </div>
    </div>

    <!-- Right Pane - Chat Messages -->
    <div class="chat-messages">
      <div class="chat-messages-empty" id="emptyState">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <h3 style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">Select a chat to view messages</h3>
        <p style="font-size: 14px;">Choose a conversation from the list to see the full chat history</p>
      </div>

      <div id="chatContent" style="display: none; height: 100%; display: flex; flex-direction: column;">
        <div class="chat-messages-header" id="chatHeader">
          <!-- Header will be populated dynamically -->
        </div>
        <div class="chat-messages-content" id="chatMessagesContent">
          <!-- Messages will be loaded here -->
        </div>
      </div>
    </div>
  </div>

  <script>
    let currentUserId = null;
    let allUsers = <%- JSON.stringify(users || []) %>;
    let filteredUsers = [...allUsers];
    let currentPage = 1;
    let isLoadingUsers = false;
    let hasMoreUsers = true;
    let isSearchActive = false;

    // Event delegation for chat items
    document.getElementById('chatListItems').addEventListener('click', (e) => {
      const chatItem = e.target.closest('.chat-item');
      if (chatItem) {
        const userId = chatItem.dataset.userId;
        loadChat(userId);
      }
    });

    // Search functionality
    document.getElementById('searchChats').addEventListener('input', (e) => {
      const searchTerm = e.target.value.toLowerCase();
      isSearchActive = searchTerm.length > 0;

      filteredUsers = allUsers.filter(user => {
        const name = (user.name || '').toLowerCase();
        const firstName = (user.first_name || '').toLowerCase();
        const lastName = (user.last_name || '').toLowerCase();
        const phone = (user.phone_number || '').toLowerCase();
        return name.includes(searchTerm) ||
               firstName.includes(searchTerm) ||
               lastName.includes(searchTerm) ||
               phone.includes(searchTerm);
      });
      renderChatList();
    });

    function renderChatList() {
      const container = document.getElementById('chatListItems');
      if (filteredUsers.length === 0) {
        container.innerHTML = '<div style="padding: 40px; text-align: center; color: #9ca3af;">No users found</div>';
        return;
      }

      container.innerHTML = filteredUsers.map(user => {
        const displayName = user.first_name ? `${user.first_name} ${user.last_name || ''}` : (user.name || user.phone_number || 'Unknown User');
        const registrationBadge = user.registration_state ?
          `<span style="font-size: 11px; padding: 2px 6px; border-radius: 4px; margin-left: 8px; background: ${
            user.registration_state === 'completed' ? '#10b981' :
            user.registration_state === 'flow_sent' ? '#f59e0b' :
            user.registration_state === 'invited' ? '#3b82f6' : '#6b7280'
          }; color: white; font-weight: 500;">
            ${user.registration_state === 'completed' ? '✓ Registered' :
              user.registration_state === 'flow_sent' ? '📋 Form Sent' :
              user.registration_state === 'invited' ? '📨 Invited' : user.registration_state}
          </span>` : '';

        const registrationInfo = user.registration_started_at && !user.registration_completed ?
          ` • Reg started ${new Date(user.registration_started_at).toLocaleDateString()}` :
          user.registration_completed_at ?
          ` • Reg completed ${new Date(user.registration_completed_at).toLocaleDateString()}` : '';

        return `
          <div class="chat-item ${currentUserId === user.id ? 'active' : ''}" data-user-id="${user.id}">
            <div class="chat-item-avatar">
              ${(user.first_name || user.name || user.phone_number || 'U').charAt(0).toUpperCase()}
            </div>
            <div class="chat-item-content">
              <div class="chat-item-name">
                ${displayName}${registrationBadge}
              </div>
              <div class="chat-item-last-message">
                ${user.phone_number || 'No phone number'}${registrationInfo}
              </div>
            </div>
            <div class="chat-item-time">
              ${user.created_at ? new Date(user.created_at).toLocaleDateString() : ''}
            </div>
          </div>
        `;
      }).join('');
    }

    async function loadChat(userId) {
      if (currentUserId === userId) return;

      currentUserId = userId;

      // Reset message pagination
      currentMessageOffset = 0;
      hasMoreMessages = true;

      // Update active state
      document.querySelectorAll('.chat-item').forEach(item => {
        item.classList.toggle('active', item.dataset.userId === userId);
      });

      // Show loading state
      document.getElementById('emptyState').style.display = 'none';
      document.getElementById('chatContent').style.display = 'flex';
      document.getElementById('chatMessagesContent').innerHTML = '<div style="display: flex; justify-content: center; padding: 40px;"><div class="loading-spinner"></div></div>';

      try {
        const response = await fetch(`/observability/api/conversations/${userId}?limit=100`);

        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();

        if (data.success) {
          hasMoreMessages = data.hasMoreMessages || false;
          currentMessageOffset = data.conversations.length;
          renderChat(data);
        } else {
          throw new Error(data.error || 'Failed to load chat');
        }
      } catch (error) {
        document.getElementById('chatMessagesContent').innerHTML = `
          <div style="text-align: center; padding: 40px; color: #ef4444;">
            <p>Failed to load messages</p>
            <p style="font-size: 12px; color: #9ca3af; margin-top: 8px;">${error.message}</p>
            <button onclick="loadChat('${userId}')" style="margin-top: 12px; padding: 8px 16px; background: #4f46e5; color: white; border-radius: 6px; border: none; cursor: pointer;">
              Try Again
            </button>
          </div>
        `;
      }
    }

    function renderChat(data) {
      const { user, conversations, coachingSessions, lessonPlans, videoRequests, readingSessions } = data;

      // Render header
      const displayName = user.first_name ? `${user.first_name} ${user.last_name || ''}` : (user.name || user.phone_number || 'Unknown User');
      const registrationBadge = user.registration_state ?
        `<span style="font-size: 11px; padding: 2px 6px; border-radius: 4px; margin-left: 8px; background: ${
          user.registration_state === 'completed' ? '#10b981' :
          user.registration_state === 'flow_sent' ? '#f59e0b' :
          user.registration_state === 'invited' ? '#3b82f6' : '#6b7280'
        }; color: white; font-weight: 500;">
          ${user.registration_state === 'completed' ? '✓ Registered' :
            user.registration_state === 'flow_sent' ? '📋 Form Sent' :
            user.registration_state === 'invited' ? '📨 Invited' : user.registration_state}
        </span>` : '';

      const registrationInfo = user.registration_started_at && !user.registration_completed ?
        ` • Reg started ${new Date(user.registration_started_at).toLocaleDateString()}` :
        user.registration_completed_at ?
        ` • Reg completed ${new Date(user.registration_completed_at).toLocaleDateString()}` : '';

      document.getElementById('chatHeader').innerHTML = `
        <div class="chat-messages-header-avatar">
          ${(user.first_name || user.name || user.phone_number || 'U').charAt(0).toUpperCase()}
        </div>
        <div class="chat-messages-header-info">
          <h3>${displayName}${registrationBadge}</h3>
          <p>${user.phone_number || 'No phone number'} • ${conversations.length} messages${registrationInfo}</p>
        </div>
      `;

      // Create timeline with all user activities
      const timeline = [];

      // Add conversations
      conversations.forEach(msg => {
        timeline.push({
          type: 'message',
          timestamp: new Date(msg.created_at),
          data: msg
        });
      });

      // Add lesson plans
      lessonPlans.forEach(plan => {
        timeline.push({
          type: 'lesson_plan',
          timestamp: new Date(plan.created_at),
          data: plan
        });
      });

      // Add coaching sessions
      coachingSessions.forEach(session => {
        timeline.push({
          type: 'coaching_session',
          timestamp: new Date(session.created_at),
          data: session
        });
      });

      // Add video requests (AI Video Generation)
      if (videoRequests) {
        videoRequests.forEach(video => {
          timeline.push({
            type: 'video_request',
            timestamp: new Date(video.created_at),
            data: video
          });
        });
      }

      // Add reading sessions (Reading Assessment)
      if (readingSessions) {
        readingSessions.forEach(session => {
          timeline.push({
            type: 'reading_session',
            timestamp: new Date(session.created_at),
            data: session
          });
        });
      }

      // Add registration events to timeline
      if (user.registration_started_at) {
        timeline.push({
          type: 'registration_sent',
          timestamp: new Date(user.registration_started_at),
          data: { state: user.registration_state }
        });
      }
      if (user.registration_completed_at) {
        timeline.push({
          type: 'registration_completed',
          timestamp: new Date(user.registration_completed_at),
          data: { firstName: user.first_name, lastName: user.last_name }
        });
      }

      // Sort by timestamp
      timeline.sort((a, b) => a.timestamp - b.timestamp);

      // Render timeline
      let html = '';
      let lastDate = null;

      timeline.forEach(item => {
        const itemDate = item.timestamp.toLocaleDateString();

        // Add date separator
        if (itemDate !== lastDate) {
          html += `
            <div class="message-date">
              <span>${formatDate(item.timestamp)}</span>
            </div>
          `;
          lastDate = itemDate;
        }

        if (item.type === 'message') {
          html += renderMessage(item.data);
        } else if (item.type === 'lesson_plan') {
          html += renderLessonPlan(item.data);
        } else if (item.type === 'coaching_session') {
          html += renderCoachingSession(item.data);
        } else if (item.type === 'video_request') {
          html += renderVideoRequest(item.data);
        } else if (item.type === 'reading_session') {
          html += renderReadingSession(item.data);
        } else if (item.type === 'registration_sent') {
          html += renderRegistrationSent(item.timestamp);
        } else if (item.type === 'registration_completed') {
          html += renderRegistrationCompleted(item.timestamp, item.data);
        }
      });

      document.getElementById('chatMessagesContent').innerHTML = html;

      // Scroll to bottom
      document.getElementById('chatMessagesContent').scrollTop = document.getElementById('chatMessagesContent').scrollHeight;
    }

    function renderMessage(msg) {
      const role = msg.role === 'user' ? 'user' : 'assistant';
      const time = new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

      let content = msg.content || '';

      // Handle audio messages
      if (msg.message_type === 'voice' && msg.media_url) {
        content = `
          <div class="audio-message">
            <button class="audio-play-btn" onclick="playAudio('${msg.media_url}')">
              ▶
            </button>
            <div class="audio-waveform"></div>
            <span style="font-size: 12px; color: #667781;">0:${Math.floor(Math.random() * 60)}</span>
          </div>
        `;
      } else {
        content = escapeHtml(content).replace(/\n/g, '<br>');
      }

      return `
        <div class="message ${role}">
          <div class="message-bubble">
            ${content}
            <div class="message-time">${time}</div>
          </div>
        </div>
      `;
    }

    function renderLessonPlan(plan) {
      return `
        <div class="message assistant">
          <div class="inline-card">
            <div class="inline-card-header">
              <div class="inline-card-icon lesson-plan">
                📚
              </div>
              <div>
                <div class="inline-card-title">Lesson Plan Created</div>
                <div class="inline-card-subtitle">${plan.type || 'Lesson Plan'}</div>
              </div>
            </div>
            <div class="inline-card-content">
              <strong>Topic:</strong> ${escapeHtml(plan.topic || 'N/A')}<br>
              <strong>Grade:</strong> ${escapeHtml(plan.grade || 'N/A')}<br>
              <strong>Subject:</strong> ${escapeHtml(plan.subject || 'N/A')}
            </div>
            <div class="inline-card-actions">
              ${plan.gamma_url ? `<a href="${plan.gamma_url}" target="_blank" class="inline-card-btn inline-card-btn-primary">View Presentation</a>` : ''}
            </div>
          </div>
        </div>
      `;
    }

    function renderCoachingSession(session) {
      const statusColor = session.status === 'completed' ? '#10b981' : '#f59e0b';
      return `
        <div class="message assistant">
          <div class="inline-card">
            <div class="inline-card-header">
              <div class="inline-card-icon coaching-session">
                🎯
              </div>
              <div>
                <div class="inline-card-title">Coaching Session</div>
                <div class="inline-card-subtitle" style="color: ${statusColor}; font-weight: 600;">${session.status || 'Pending'}</div>
              </div>
            </div>
            <div class="inline-card-content">
              Session completed with detailed analysis and feedback
            </div>
            <div class="inline-card-actions">
              ${session.report_gamma_url ? `<a href="${session.report_gamma_url}" target="_blank" class="inline-card-btn inline-card-btn-primary">View Report</a>` : ''}
              ${session.audio_url ? `<a href="${session.audio_url}" target="_blank" class="inline-card-btn inline-card-btn-secondary">Listen Audio</a>` : ''}
            </div>
          </div>
        </div>
      `;
    }

    function renderVideoRequest(video) {
      const statusColor = video.status === 'completed' ? '#10b981' : video.status === 'processing' ? '#3b82f6' : video.status === 'failed' ? '#ef4444' : '#f59e0b';
      const statusLabel = video.status === 'completed' ? 'Completed' : video.status === 'processing' ? 'Processing' : video.status === 'failed' ? 'Failed' : 'Pending';
      return `
        <div class="message assistant">
          <div class="inline-card">
            <div class="inline-card-header">
              <div class="inline-card-icon" style="background: #e0e7ff; color: #4338ca;">
                🎬
              </div>
              <div>
                <div class="inline-card-title">AI Video Generation</div>
                <div class="inline-card-subtitle" style="color: ${statusColor}; font-weight: 600;">${statusLabel}</div>
              </div>
            </div>
            <div class="inline-card-content">
              <strong>Topic:</strong> ${escapeHtml(video.topic || 'N/A')}<br>
              <strong>Language:</strong> ${video.language || 'N/A'}
            </div>
            <div class="inline-card-actions">
              ${video.video_url && video.status === 'completed' ? `<a href="${video.video_url}" target="_blank" class="inline-card-btn inline-card-btn-primary">Watch Video</a>` : ''}
              ${video.pdf_url ? `<a href="${video.pdf_url}" target="_blank" class="inline-card-btn inline-card-btn-secondary">View PDF</a>` : ''}
            </div>
          </div>
        </div>
      `;
    }

    function renderReadingSession(session) {
      const statusColor = session.status === 'completed' ? '#10b981' : '#f59e0b';
      const accuracyScore = session.accuracy_percentage ? `${Math.round(session.accuracy_percentage)}%` : 'N/A';
      const wcpmScore = session.wcpm ? `${Math.round(session.wcpm)} WCPM` : 'N/A';
      return `
        <div class="message assistant">
          <div class="inline-card">
            <div class="inline-card-header">
              <div class="inline-card-icon" style="background: #fce7f3; color: #be185d;">
                📖
              </div>
              <div>
                <div class="inline-card-title">Reading Assessment</div>
                <div class="inline-card-subtitle" style="color: ${statusColor}; font-weight: 600;">${session.status || 'Pending'}</div>
              </div>
            </div>
            <div class="inline-card-content">
              <strong>Language:</strong> ${session.language || 'N/A'}<br>
              <strong>Grade Level:</strong> ${session.grade_level || 'N/A'}<br>
              <strong>Accuracy:</strong> ${accuracyScore} | <strong>Fluency:</strong> ${wcpmScore}
            </div>
          </div>
        </div>
      `;
    }

    function renderRegistrationSent(timestamp) {
      const time = timestamp.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      return `
        <div class="message-date" style="margin: 16px 0;">
          <span style="background: #FEF3C7; color: #92400E; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 500; display: inline-flex; align-items: center; gap: 8px;">
            📋 <strong>Registration Form Sent</strong> at ${time}
          </span>
        </div>
      `;
    }

    function renderRegistrationCompleted(timestamp, data) {
      const time = timestamp.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      const name = data.firstName ? `${data.firstName} ${data.lastName || ''}`.trim() : 'User';
      return `
        <div class="message-date" style="margin: 16px 0;">
          <span style="background: #D1FAE5; color: #065F46; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 500; display: inline-flex; align-items: center; gap: 8px;">
            ✅ <strong>Registration Completed</strong> by ${name} at ${time}
          </span>
        </div>
      `;
    }

    function formatDate(date) {
      const today = new Date();
      const yesterday = new Date(today);
      yesterday.setDate(yesterday.getDate() - 1);

      if (date.toDateString() === today.toDateString()) {
        return 'Today';
      } else if (date.toDateString() === yesterday.toDateString()) {
        return 'Yesterday';
      } else {
        return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
      }
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function playAudio(url) {
      const audio = new Audio(url);
      audio.play();
    }

    // Infinite scroll for user list
    const chatListContainer = document.querySelector('.chat-list-items');
    chatListContainer.addEventListener('scroll', () => {
      // Check if scrolled to bottom
      const scrollTop = chatListContainer.scrollTop;
      const scrollHeight = chatListContainer.scrollHeight;
      const clientHeight = chatListContainer.clientHeight;

      // Trigger load when 100px from bottom
      if (scrollHeight - scrollTop - clientHeight < 100 && !isLoadingUsers && hasMoreUsers && !isSearchActive) {
        loadMoreUsers();
      }
    });

    async function loadMoreUsers() {
      if (isLoadingUsers || !hasMoreUsers) return;
      isLoadingUsers = true;

      document.getElementById('userListLoading').style.display = 'block';

      try {
        const response = await fetch(`/observability/api/users?page=${currentPage + 1}`);
        const data = await response.json();

        if (data.success && data.users.length > 0) {
          // Append new users to existing list
          allUsers = [...allUsers, ...data.users];
          filteredUsers = [...allUsers];
          currentPage++;
          hasMoreUsers = data.hasMore;

          renderChatList();
        } else {
          hasMoreUsers = false;
        }
      } catch (error) {
        console.error('Error loading more users:', error);
      } finally {
        isLoadingUsers = false;
        document.getElementById('userListLoading').style.display = 'none';
      }
    }

    // Infinite scroll for chat messages (scroll UP to load older)
    let isLoadingMessages = false;
    let hasMoreMessages = true;
    let currentMessageOffset = 0;
    const messagesPerPage = 50;

    function setupMessageScroll() {
      const messagesContainer = document.getElementById('chatMessagesContent');
      messagesContainer.addEventListener('scroll', () => {
        // Check if scrolled to top
        if (messagesContainer.scrollTop < 100 && !isLoadingMessages && hasMoreMessages) {
          loadOlderMessages();
        }
      });
    }

    async function loadOlderMessages() {
      if (!currentUserId || isLoadingMessages || !hasMoreMessages) return;
      isLoadingMessages = true;

      const messagesContainer = document.getElementById('chatMessagesContent');
      const oldScrollHeight = messagesContainer.scrollHeight;

      // Show loading indicator at top
      const loadingDiv = document.createElement('div');
      loadingDiv.id = 'messagesLoading';
      loadingDiv.style.cssText = 'padding: 16px; text-align: center; color: #6b7280;';
      loadingDiv.innerHTML = '<div class="loading-spinner" style="margin: 0 auto;"></div><p style="font-size: 13px; margin-top: 8px;">Loading older messages...</p>';
      messagesContainer.insertBefore(loadingDiv, messagesContainer.firstChild);

      try {
        currentMessageOffset += messagesPerPage;
        const response = await fetch(`/observability/api/conversations/${currentUserId}?offset=${currentMessageOffset}&limit=${messagesPerPage}`);
        const data = await response.json();

        if (data.success && data.conversations.length > 0) {
          // Prepend older messages to timeline
          // This requires modifying the renderChat function to support appending
          // For now, we'll just indicate there are more messages
          hasMoreMessages = data.hasMoreMessages;

          // TODO: Implement prepending older messages without re-rendering entire chat
          console.log('Loaded', data.conversations.length, 'older messages');
        } else {
          hasMoreMessages = false;
        }
      } catch (error) {
        console.error('Error loading older messages:', error);
      } finally {
        isLoadingMessages = false;
        const loadingDiv = document.getElementById('messagesLoading');
        if (loadingDiv) {
          loadingDiv.remove();
        }

        // Maintain scroll position
        const newScrollHeight = messagesContainer.scrollHeight;
        messagesContainer.scrollTop = newScrollHeight - oldScrollHeight;
      }
    }

    // Initialize message scroll listener
    setupMessageScroll();
  </script>
</body>
</html>
