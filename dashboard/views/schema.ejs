  <script>
    // Initialize Mermaid
    mermaid.initialize({
      startOnLoad: true,
      theme: 'default',
      securityLevel: 'loose'
    });

    // Toggle field details
    function toggleFields(tableId) {
      const fieldList = document.getElementById(tableId + '-fields');
      if (fieldList) {
        fieldList.classList.toggle('active');
        const button = fieldList.previousElementSibling;
        if (fieldList.classList.contains('active')) {
          button.textContent = '- Hide fields';
        } else {
          button.textContent = '+ Show fields';
        }
      }
    }
  </script>
