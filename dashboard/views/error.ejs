<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Rumi Observability Portal</title>
  <link rel="icon" type="image/png" href="/images/rumi-logo.png">
  <link rel="stylesheet" href="/css/main.css">
  </style>
</head>
<body class="bg-background min-h-screen flex items-center justify-center">
  <div class="max-w-md w-full card-primary p-8">
    <div class="text-center">
      <svg class="mx-auto h-16 w-16 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
      </svg>
      <h1 class="mt-4 text-2xl font-bold text-foreground"><%= message %></h1>
      <p class="mt-2 text-muted-foreground"><%= error %></p>
      <div class="mt-6">
        <% if (isAuthenticated) { %>
          <a href="/observability/dashboard" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
            Back to Dashboard
          </a>
        <% } else { %>
          <a href="/login" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
            Go to Login
          </a>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
