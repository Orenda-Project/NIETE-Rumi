{
  "name": "rumi-bot",
  "version": "1.1.0",
  "description": "Rumi - AI Teaching Assistant for WhatsApp",
  "main": "whatsapp-bot.js",
  "scripts": {
    "start": "node whatsapp-bot.js",
    "start:dashboard": "node dashboard/index.js",
    "start:worker": "node workers/sqs-worker.js",
    "start:stale-worker": "node workers/stale-session.worker.js",
    "test:jest": "jest",
    "dev": "node whatsapp-bot.js",
    "dev:dashboard": "node dashboard/index.js",
    "dev:worker": "node workers/sqs-worker.js",
    "simulate": "node scripts/testing/simulate-webhook.js",
    "postinstall": "node -e \"process.env.SKIP_PLAYWRIGHT_INSTALL==='1' ? process.exit(0) : require('child_process').execSync('npx --yes playwright@' + require('playwright-core/package.json').version + ' install ' + (process.getuid && process.getuid()===0 ? '--with-deps ' : '') + 'chromium', { stdio: 'inherit' })\""
  },
  "keywords": [
    "whatsapp",
    "chatbot",
    "ai",
    "education",
    "teaching-assistant",
    "rumi"
  ],
  "author": "Orenda Project",
  "license": "Apache-2.0",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.922.0",
    "@aws-sdk/client-textract": "^3.922.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.78.0",
    "@turbodocx/html-to-docx": "^1.22.0",
    "aws-sdk": "^2.1691.0",
    "axios": "^1.13.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.1",
    "docx": "^9.5.0",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.4",
    "ioredis": "^5.4.1",
    "jsonrepair": "^3.13.1",
    "mammoth": "^1.8.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.40.0",
    "openai": "^6.7.0",
    "p-limit": "^3.1.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "pino": "^10.1.0",
    "playwright-core": "^1.60.0",
    "sharp": "^0.34.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.3"
  },
  "optionalDependencies": {
    "canvas": "^3.2.0",
    "chart.js": "^3.5.1",
    "chartjs-node-canvas": "^4.1.6"
  }
}
